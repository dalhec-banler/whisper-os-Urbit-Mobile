+
+    private List<HostedApp> loadHostedApps() {
+        List<HostedApp> apps = readHostedAppsFromProvider();
+        if (!apps.isEmpty()) {
+            return apps;
+        }
+
+        ArrayList<HostedApp> fallback = new ArrayList<>();
+        fallback.add(new HostedApp("tlon", "Tlon", "waiting for ship inventory", null,
+                null, null, AMBER));
+        fallback.add(new HostedApp("dojo", "Dojo", "waiting for ship inventory", null,
+                null, null,
+                Color.rgb(93, 85, 71)));
+        return fallback;
+    }
+
+    private List<HostedApp> readHostedAppsFromProvider() {
+        ArrayList<HostedApp> apps = new ArrayList<>();
+
+        try {
+            Bundle result = getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getHostedApps", null, null);
+            if (result == null) {
+                return apps;
+            }
+            String json = result.getString("json", "");
+            if (TextUtils.isEmpty(json)) {
+                return apps;
+            }
+            JSONArray array = new JSONObject(json).optJSONArray("apps");
+            if (array == null) {
+                return apps;
+            }
+
+            for (int i = 0; i < array.length(); i++) {
+                JSONObject app = array.optJSONObject(i);
+                if (app == null) {
+                    continue;
+                }
+                String id = app.optString("id", "");
+                String title = app.optString("title", "");
+                String desk = app.optString("desk", "");
+                String launchMode = normalizeLaunchMode(app.optString("launchMode", ""));
+                String androidPackage = app.optString("androidPackage", "");
+                String startUrl = app.optString("startUrl", "");
+                String basePath = app.optString("basePath", "");
+                if (TextUtils.isEmpty(startUrl) && !TextUtils.isEmpty(basePath)) {
+                    startUrl = "http://127.0.0.1:12321" + basePath;
+                }
+                if (TextUtils.isEmpty(id) || TextUtils.isEmpty(title)) {
+                    continue;
+                }
+                apps.add(new HostedApp(id, title, desk, launchMode, androidPackage, startUrl,
+                        parseColor(app.optString("tileColor", ""), AMBER)));
+            }
+        } catch (Exception ignored) {
+            apps.clear();
+        }
+        return apps;
+    }
+
+    private void handleOpenHostedApp(HostedApp app) {
+        Log.d(TAG, "open hosted app id=" + app.id + " mode=" + app.launchMode
+                + " nativePackage=" + app.androidPackage);
+        if (!app.canOpen()) {
+            Toast.makeText(this, app.pendingReason(), Toast.LENGTH_SHORT).show();
+            return;
+        }
+        if (LAUNCH_NATIVE.equals(app.launchMode)) {
+            openNativeApp(app);
+        } else if (LAUNCH_PWA.equals(app.launchMode)
+                || LAUNCH_LOCAL_WEBVIEW.equals(app.launchMode)) {
+            openHostedShell(app);
+        } else if (LAUNCH_BROWSER.equals(app.launchMode)) {
+            openBrowserFallback(app.startUrl);
+        } else {
+            Toast.makeText(this, "Hosted app shell is not installed yet", Toast.LENGTH_SHORT)
+                    .show();
+        }
+    }
+
+    private void openNativeApp(HostedApp app) {
+        PackageManager packageManager = getPackageManager();
+        Intent intent = packageManager.getLaunchIntentForPackage(app.androidPackage);
+        if (intent == null) {
+            Toast.makeText(this, "Native app is not installed", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        startActivity(intent);
+    }
+
+    private void openHostedShell(HostedApp app) {
+        try {
+            startActivity(new Intent(this, WhisperHostedWebActivity.class)
+                    .putExtra(WhisperHostedWebActivity.EXTRA_TITLE, app.title)
+                    .putExtra(WhisperHostedWebActivity.EXTRA_SUBTITLE, app.subtitle())
+                    .putExtra(WhisperHostedWebActivity.EXTRA_URL, app.startUrl));
+        } catch (RuntimeException e) {
+            Log.e(TAG, "failed to start hosted app shell", e);
+            Toast.makeText(this, "Hosted app shell failed to start", Toast.LENGTH_SHORT).show();
+        }
+    }
+
+    private void openBrowserFallback(String url) {
+        if (TextUtils.isEmpty(url)) {
+            Toast.makeText(this, "Hosted app is missing a URL", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        startActivity(new Intent(Intent.ACTION_VIEW, Uri.parse(url)));
+    }
+
+    private void pinHostedApp(HostedApp app) {
+        if (isHostedAppPinned(this, app.id)) {
+            Toast.makeText(this, app.title + " is already on Home", Toast.LENGTH_SHORT).show();
+            recreate();
+            return;
+        }
+
+        Launcher launcher = Launcher.ACTIVITY_TRACKER.getCreatedContext();
+        if (launcher != null) {
+            WorkspaceItemInfo info = createWorkspaceItem(this, app);
+            boolean added = launcher.getAccessibilityDelegate().addToWorkspace(info,
+                    false /* accessibility */, success -> Toast.makeText(this,
+                            success ? app.title + " pinned to Home" : "No room on Home",
+                            Toast.LENGTH_SHORT).show());
+            if (added) {
+                return;
+            }
+        }
+
+        savePendingPin(app);
+        startActivity(new Intent(Intent.ACTION_MAIN)
+                .addCategory(Intent.CATEGORY_HOME)
+                .setFlags(Intent.FLAG_ACTIVITY_NEW_TASK));
+    }
+
+    public static void maybeCompletePendingPin(Launcher launcher) {
+        if (launcher == null) {
+            return;
+        }
+        android.content.SharedPreferences prefs = launcher.getSharedPreferences(PREFS,
+                Context.MODE_PRIVATE);
+        if (!prefs.getBoolean(PREF_PENDING_PIN, false)) {
+            return;
+        }
+
+        HostedApp app = new HostedApp(
+                prefs.getString(PREF_ID, ""),
+                prefs.getString(PREF_TITLE, ""),
+                prefs.getString(PREF_DESK, ""),
+                prefs.getString(PREF_LAUNCH_MODE, ""),
+                prefs.getString(PREF_ANDROID_PACKAGE, ""),
+                prefs.getString(PREF_START_URL, ""),
+                prefs.getInt(PREF_TILE_COLOR, AMBER));
+        prefs.edit().clear().apply();
+
+        if (!app.canOpen()) {
+            Toast.makeText(launcher, "Hosted app is not ready to pin", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        if (isHostedAppPinned(launcher, app.id)) {
+            Toast.makeText(launcher, app.title + " is already on Home", Toast.LENGTH_SHORT).show();
+            return;
+        }
+
+        WorkspaceItemInfo info = createWorkspaceItem(launcher, app);
+        launcher.getAccessibilityDelegate().addToWorkspace(info, false /* accessibility */,
+                success -> Toast.makeText(launcher,
+                        success ? app.title + " pinned to Home" : "No room on Home",
+                        Toast.LENGTH_SHORT).show());
+    }
+
+    private void savePendingPin(HostedApp app) {
+        getSharedPreferences(PREFS, Context.MODE_PRIVATE).edit()
+                .putBoolean(PREF_PENDING_PIN, true)
+                .putString(PREF_ID, app.id)
+                .putString(PREF_TITLE, app.title)
+                .putString(PREF_DESK, app.desk)
+                .putString(PREF_LAUNCH_MODE, app.launchMode)
+                .putString(PREF_ANDROID_PACKAGE, app.androidPackage)
+                .putString(PREF_START_URL, app.startUrl)
+                .putInt(PREF_TILE_COLOR, app.tileColor)
+                .apply();
+    }
+
+    private static boolean isHostedAppPinned(Context context, String id) {
+        return loadPinnedHostedIds(context).contains(id);
+    }
+
+    private static Set<String> loadPinnedHostedIds(Context context) {
+        HashSet<String> ids = new HashSet<>();
+        File dbFile = context.getDatabasePath(InvariantDeviceProfile.INSTANCE.get(context).dbFile);
+        if (!dbFile.exists()) {
+            return ids;
+        }
+
+        String[] columns = {
+                LauncherSettings.Favorites.INTENT,
+                LauncherSettings.Favorites.ITEM_TYPE,
+                LauncherSettings.Favorites.CONTAINER,
+        };
+        String selection = LauncherSettings.Favorites.CONTAINER + "=? AND "
+                + LauncherSettings.Favorites.ITEM_TYPE + "=?";
+        String[] args = {
+                String.valueOf(LauncherSettings.Favorites.CONTAINER_DESKTOP),
+                String.valueOf(LauncherSettings.Favorites.ITEM_TYPE_SHORTCUT),
+        };
+
+        try (SQLiteDatabase db = SQLiteDatabase.openDatabase(dbFile.getPath(), null,
+                SQLiteDatabase.OPEN_READONLY);
+                Cursor cursor = db.query(LauncherSettings.Favorites.TABLE_NAME, columns,
+                        selection, args, null, null, null)) {
+            if (cursor == null) {
+                return ids;
+            }
+            int intentIndex = cursor.getColumnIndexOrThrow(LauncherSettings.Favorites.INTENT);
+            while (cursor.moveToNext()) {
+                Intent intent = Intent.parseUri(cursor.getString(intentIndex), 0);
+                if (ACTION_OPEN_URBIT_APP.equals(intent.getAction())) {
+                    String id = intent.getStringExtra("id");
+                    if (!TextUtils.isEmpty(id)) {
+                        ids.add(id);
+                    }
+                }
+            }
+        } catch (Exception e) {
+            Log.w(TAG, "failed to read pinned hosted app ids", e);
+            ids.clear();
+        }
+        return ids;
+    }
+
+    private static WorkspaceItemInfo createWorkspaceItem(Context context, HostedApp app) {
+        Intent launch = new Intent(ACTION_OPEN_URBIT_APP)
+                .setClass(context, WhisperHostedAppsActivity.class)
+                .putExtra("id", app.id)
+                .putExtra("title", app.title)
+                .putExtra("desk", app.desk)
+                .putExtra("launchMode", app.launchMode)
+                .putExtra("androidPackage", app.androidPackage)
+                .putExtra("startUrl", app.startUrl);
+
+        WorkspaceItemInfo info = new WorkspaceItemInfo();
+        info.itemType = LauncherSettings.Favorites.ITEM_TYPE_SHORTCUT;
+        info.title = app.title;
+        info.intent = launch;
+        info.user = android.os.Process.myUserHandle();
+        info.bitmap = BitmapInfo.of(createHostedIcon(app), app.tileColor, IconShape.EMPTY);
+        info.contentDescription = app.title;
+        return info;
+    }
+
+    private static Bitmap createHostedIcon(HostedApp app) {
+        return WhisperAppGlyphs.createIcon(app.id, app.desk, null, 144);
+    }
+
+    private static int inkFor(int color) {
+        double luminance = 0.2126 * Color.red(color)
+                + 0.7152 * Color.green(color)
+                + 0.0722 * Color.blue(color);
+        return luminance > 150 ? Color.rgb(16, 14, 10) : PAPER;
+    }
+
+    private static int parseColor(String value, int fallback) {
+        if (TextUtils.isEmpty(value)) {
+            return fallback;
+        }
+        try {
+            return Color.parseColor(value);
+        } catch (IllegalArgumentException e) {
+            return fallback;
+        }
+    }
+
+    private static String normalizeLaunchMode(String value) {
+        if (LAUNCH_NATIVE.equals(value) || LAUNCH_PWA.equals(value)
+                || LAUNCH_LOCAL_WEBVIEW.equals(value) || LAUNCH_BROWSER.equals(value)) {
+            return value;
+        }
+        return "";
+    }
+
+    private TextView text(String value, int sp, int color, int style) {
+        TextView view = new TextView(this);
+        view.setText(value);
+        view.setTextSize(sp);
+        view.setTextColor(color);
+        view.setIncludeFontPadding(true);
+        view.setTypeface(Typeface.DEFAULT, style);
+        return view;
+    }
+
+    private GradientDrawable box(int fill, int stroke, int radius) {
+        GradientDrawable drawable = new GradientDrawable();
+        drawable.setColor(fill);
+        drawable.setCornerRadius(radius);
+        drawable.setStroke(dp(1), stroke);
+        return drawable;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private int getStatusBarHeight() {
+        int resourceId = getResources().getIdentifier("status_bar_height", "dimen", "android");
+        if (resourceId > 0) {
+            return getResources().getDimensionPixelSize(resourceId);
+        }
+        return 0;
+    }
+
+    private static final class HostedApp {
+        final String id;
+        final String title;
+        final String desk;
+        final String launchMode;
+        final String androidPackage;
+        final String startUrl;
+        final int tileColor;
+
+        HostedApp(String id, String title, String desk, String launchMode, String androidPackage,
+                String startUrl, int tileColor) {
+            this.id = id;
+            this.title = title;
+            this.desk = desk;
+            this.launchMode = TextUtils.isEmpty(launchMode) ? "" : launchMode;
+            this.androidPackage = TextUtils.isEmpty(androidPackage) ? "" : androidPackage;
+            this.startUrl = TextUtils.isEmpty(startUrl) ? "" : startUrl;
+            this.tileColor = tileColor;
+        }
+
+        String subtitle() {
+            if (TextUtils.isEmpty(desk)) {
+                return "ship app";
+            }
+            return desk.indexOf(' ') >= 0 ? desk : "%" + desk;
+        }
+
+        boolean canOpen() {
+            if (LAUNCH_NATIVE.equals(launchMode)) {
+                return !TextUtils.isEmpty(androidPackage);
+            }
+            if (LAUNCH_PWA.equals(launchMode) || LAUNCH_LOCAL_WEBVIEW.equals(launchMode)
+                    || LAUNCH_BROWSER.equals(launchMode)) {
+                return !TextUtils.isEmpty(startUrl);
+            }
+            return false;
+        }
+
+        String pendingReason() {
+            if (LAUNCH_PWA.equals(launchMode) || LAUNCH_LOCAL_WEBVIEW.equals(launchMode)) {
+                return "Hosted app is missing a URL";
+            }
+            return "Waiting for ship app inventory";
+        }
+    }
+}
