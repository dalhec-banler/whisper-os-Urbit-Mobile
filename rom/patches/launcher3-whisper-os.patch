+package com.android.launcher3;
+
+import static com.android.launcher3.model.data.ItemInfoWithIcon.FLAG_SYSTEM_YES;
+
+import android.content.ComponentName;
+import android.content.Context;
+
+import com.android.launcher3.model.data.ItemInfoWithIcon;
+
+/**
+ * Whisper OS app provenance classification.
+ *
+ * <p>This is intentionally small and deterministic. Rich Urbit-hosted apps will eventually come
+ * from the controller/moon model, but Android packages still need a stable visual class inside
+ * Launcher3.</p>
+ */
+public final class WhisperAppProvenance {
+
+    public static final int NONE = 0;
+    public static final int SYSTEM = 1;
+    public static final int STORE = 2;
+    public static final int SANDBOXED = 3;
+    public static final int URBIT = 4;
+
+    private WhisperAppProvenance() {
+    }
+
+    public static int from(ItemInfoWithIcon info) {
+        ComponentName componentName = info.getTargetComponent();
+        if (isHostedAppsComponent(componentName)) {
+            return URBIT;
+        }
+
+        String packageName = info.getTargetPackage();
+        if (packageName == null) {
+            return NONE;
+        }
+
+        if (isUrbitPackage(packageName)) {
+            return URBIT;
+        }
+        if (isStorePackage(packageName)) {
+            return STORE;
+        }
+        if (isSandboxedPackage(packageName)) {
+            return SANDBOXED;
+        }
+        if ((info.runtimeStatusFlags & FLAG_SYSTEM_YES) != 0) {
+            return SYSTEM;
+        }
+
+        return SANDBOXED;
+    }
+
+    public static int color(Context context, int provenance) {
+        int colorRes;
+        switch (provenance) {
+            case URBIT:
+                colorRes = R.color.whisper_urbit;
+                break;
+            case STORE:
+                colorRes = R.color.whisper_store;
+                break;
+            case SANDBOXED:
+                colorRes = R.color.whisper_sandboxed;
+                break;
+            case SYSTEM:
+                colorRes = R.color.whisper_system;
+                break;
+            default:
+                colorRes = android.R.color.transparent;
+        }
+        return context.getColor(colorRes);
+    }
+
+    private static boolean isUrbitPackage(String packageName) {
+        return packageName.startsWith("io.nativeplanet.")
+                || packageName.startsWith("network.tlon.")
+                || packageName.startsWith("org.urbit.");
+    }
+
+    private static boolean isHostedAppsComponent(ComponentName componentName) {
+        return componentName != null
+                && componentName.getPackageName().equals("com.android.launcher3")
+                && componentName.getClassName().equals(
+                        "com.android.launcher3.WhisperHostedAppsActivity");
+    }
+
+    private static boolean isStorePackage(String packageName) {
+        return packageName.equals("app.grapheneos.apps")
+                || packageName.equals("com.android.vending");
+    }
+
+    private static boolean isSandboxedPackage(String packageName) {
+        return packageName.startsWith("com.google.android.")
+                || packageName.startsWith("com.google.")
+                || packageName.startsWith("com.android.vending");
+    }
+}
