+
+        mWhisperProvenanceIconBoundsF.set(mWhisperProvenanceIconBounds);
+        float radius = mWhisperProvenanceIconBoundsF.width() / 2f;
+
+        switch (mWhisperProvenance) {
+            case WhisperAppProvenance.URBIT:
+                drawWhisperUrbitMark(canvas, stroke, radius);
+                break;
+            case WhisperAppProvenance.STORE:
+                drawWhisperBottomRail(canvas, stroke, radius, 0.58f);
+                break;
+            case WhisperAppProvenance.SANDBOXED:
+                drawWhisperCornerDot(canvas, stroke);
+                break;
+            case WhisperAppProvenance.SYSTEM:
+                drawWhisperSystemRing(canvas, stroke, radius);
+                break;
+        }
+
+        canvas.translate(-scrollX, -scrollY);
+    }
+
+    private void drawWhisperUrbitMark(Canvas canvas, int stroke, float radius) {
+        mWhisperProvenancePaint.setStyle(Paint.Style.STROKE);
+        canvas.drawRoundRect(mWhisperProvenanceIconBoundsF, radius, radius,
+                mWhisperProvenancePaint);
+
+        mWhisperProvenancePaint.setStyle(Paint.Style.FILL);
+        float dotRadius = stroke * 1.5f;
+        canvas.drawCircle(mWhisperProvenanceIconBoundsF.right - stroke * 2.2f,
+                mWhisperProvenanceIconBoundsF.top + stroke * 2.2f,
+                dotRadius,
+                mWhisperProvenancePaint);
+    }
+
+    private void drawWhisperBottomRail(Canvas canvas, int stroke, float radius, float widthFactor) {
+        float railHalfWidth = mWhisperProvenanceIconBoundsF.width() * widthFactor / 2f;
+        float centerX = mWhisperProvenanceIconBoundsF.centerX();
+        float y = mWhisperProvenanceIconBoundsF.bottom - stroke * 2f;
+        canvas.drawLine(centerX - railHalfWidth, y, centerX + railHalfWidth, y,
+                mWhisperProvenancePaint);
+    }
+
+    private void drawWhisperCornerDot(Canvas canvas, int stroke) {
+        mWhisperProvenancePaint.setStyle(Paint.Style.FILL);
+        float radius = Math.max(4, stroke * 1.8f);
+        canvas.drawCircle(mWhisperProvenanceIconBoundsF.right - stroke * 2f,
+                mWhisperProvenanceIconBoundsF.top + stroke * 2f,
+                radius,
+                mWhisperProvenancePaint);
+    }
+
+    private void drawWhisperSystemRing(Canvas canvas, int stroke, float radius) {
+        mWhisperProvenancePaint.setAlpha(170);
+        mWhisperProvenancePaint.setStyle(Paint.Style.STROKE);
+        mWhisperProvenancePaint.setStrokeWidth(Math.max(1, stroke - 1));
+        float inset = stroke * 2f;
+        float x = mWhisperProvenanceIconBoundsF.left + inset;
+        float y = mWhisperProvenanceIconBoundsF.bottom - inset;
+        canvas.drawLine(x, y, x + mWhisperProvenanceIconBoundsF.width() * 0.22f, y,
+                mWhisperProvenancePaint);
+        mWhisperProvenancePaint.setAlpha(255);
+    }
+
