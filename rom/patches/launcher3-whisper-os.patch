+/*
+ * Whisper OS Design Tokens
+ * Single source of truth for colors, typography, and spacing.
+ * See design handoff: 01-foundations.md
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Color;
+import android.graphics.Typeface;
+
+public final class WhisperTokens {
+    private WhisperTokens() {}
+
+    // ─────────────────────────────────────────────────────────────
+    // 1.1 · Surface colors
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int PAPER = 0xFFF4F1EC;      // light surfaces
+    public static final int INK = 0xFF1A1916;        // warm-black surfaces, text on paper
+    public static final int DEEP = 0xFF0E0D0C;       // onboarding, full-screen identity
+
+    // Text/line tints on paper
+    public static final int INK_DIM = 0x8C1A1916;    // 55% ink
+    public static final int INK_FAINT = 0x4D1A1916;  // 30% ink
+    public static final int INK_HAIR = 0x1A1A1916;   // 10% ink (hairlines)
+
+    // Text/line tints on ink/deep
+    public static final int PAPER_DIM = 0x8CF4F1EC;    // 55% paper
+    public static final int PAPER_FAINT = 0x4DF4F1EC;  // 30% paper
+    public static final int PAPER_HAIR = 0x1AF4F1EC;   // 10% paper (hairlines)
+
+    // ─────────────────────────────────────────────────────────────
+    // 1.2 · The eight sigil palettes
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int[][] PALETTES = {
+        { 0xFF1A1A1A, 0xFFF3A712 },  // 0: Amber
+        { 0xFF10221C, 0xFF7FC7A3 },  // 1: Mint
+        { 0xFF1A1530, 0xFFA18CD1 },  // 2: Lavender
+        { 0xFF2A1A1A, 0xFFD97757 },  // 3: Coral
+        { 0xFF0E1A2A, 0xFF7DA6C9 },  // 4: Sky
+        { 0xFF1C1C1C, 0xFFE8E8E8 },  // 5: Paper
+        { 0xFF221A10, 0xFFD6B370 },  // 6: Wheat
+        { 0xFF1A1A1A, 0xFF9BB380 },  // 7: Sage
+    };
+
+    public static int paletteBg(int index) {
+        return PALETTES[Math.abs(index) % PALETTES.length][0];
+    }
+
+    public static int paletteFg(int index) {
+        return PALETTES[Math.abs(index) % PALETTES.length][1];
+    }
+
+    // Named palette indices
+    public static final int PALETTE_AMBER = 0;
+    public static final int PALETTE_MINT = 1;
+    public static final int PALETTE_LAVENDER = 2;
+    public static final int PALETTE_CORAL = 3;
+    public static final int PALETTE_SKY = 4;
+    public static final int PALETTE_PAPER = 5;
+    public static final int PALETTE_WHEAT = 6;
+    public static final int PALETTE_SAGE = 7;
+
+    // ─────────────────────────────────────────────────────────────
+    // 1.3 · System accents
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int ACCENT_AMBER = 0xFFF3A712;       // system spark, %, AI dot, unread, caret
+    public static final int ACCENT_AMBER_SOFT = 0xFFD6A35C;  // identity surfaces, urbit provenance
+    public static final int MINT = 0xFF7FC7A3;               // affirmative call actions
+    public static final int CORAL = 0xFFD97757;              // destructive, missed, decline
+
+    // ─────────────────────────────────────────────────────────────
+    // 4.2 · Provenance world colors
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int WORLD_URBIT = 0xFFD6A35C;  // urbit-native
+    public static final int WORLD_PLAY = 0xFF8FB39A;   // Google Play (sandboxed)
+    public static final int WORLD_WEB = 0xFF9AA4B3;    // web app
+    public static final int WORLD_SYS = 0xFFA89888;    // Android system
+    public static final int WORLD_DEV = 0xFFC89678;    // sideloaded/developer
+
+    // ─────────────────────────────────────────────────────────────
+    // 1.5 · Spacing (dp values)
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int SCREEN_PAD_X = 22;
+    public static final int SCREEN_PAD_X_WIDE = 24;
+    public static final int SCREEN_PAD_TOP = 60;
+    public static final int SCREEN_PAD_BOTTOM = 60;
+    public static final int GRID_GAP = 14;
+    public static final int GRID_GAP_DENSE = 10;
+    public static final int ROW_PAD_Y = 12;
+    public static final int SECTION_GAP = 24;
+
+    // App grid
+    public static final int CELL_SIZE = 62;
+    public static final int CELL_LABEL_GAP = 6;
+    public static final int DOCK_CELL_SIZE = 44;
+
+    // ─────────────────────────────────────────────────────────────
+    // 1.6 · Status strip
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int STRIP_PAD_V = 10;
+    public static final int STRIP_PAD_H = 14;
+    public static final int STRIP_TEXT_SIZE = 11;
+
+    // ─────────────────────────────────────────────────────────────
+    // Typography sizes (sp)
+    // ─────────────────────────────────────────────────────────────
+
+    public static final int TYPE_DISPLAY_XL = 88;  // lock screen clock
+    public static final int TYPE_DISPLAY_L = 44;   // home clock
+    public static final int TYPE_TITLE = 28;       // screen titles
+    public static final int TYPE_HEADLINE = 20;    // card titles
+    public static final int TYPE_BODY = 14;        // list rows, app names
+    public static final int TYPE_LABEL = 11;       // section labels, @p, timestamps
+    public static final int TYPE_MICRO = 9;        // sub-metadata
+
+    // ─────────────────────────────────────────────────────────────
+    // FNV-1a hash for @p → palette
+    // ─────────────────────────────────────────────────────────────
+
+    public static int fnv1a32(String s) {
+        int h = 0x811C9DC5;
+        for (int i = 0; i < s.length(); i++) {
+            h ^= s.charAt(i);
+            h *= 0x01000193;
+        }
+        return h;
+    }
+
+    public static int paletteIndexForPatp(String patp) {
+        int hash = fnv1a32(patp);
+        return (int) (Integer.toUnsignedLong(hash) % PALETTES.length);
+    }
+
+    public static int[] paletteForPatp(String patp) {
+        return PALETTES[paletteIndexForPatp(patp)];
+    }
+}
