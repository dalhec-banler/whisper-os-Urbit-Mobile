--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperGlyphDrawable.java
@@ -0,0 +1,114 @@
+/*
+ * Whisper OS Glyph Drawable
+ * A Drawable that renders a Whisper glyph using WhisperGlyphRenderer.
+ * Can be used anywhere a Drawable is expected (ImageView, icon, etc.)
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Canvas;
+import android.graphics.ColorFilter;
+import android.graphics.PixelFormat;
+import android.graphics.drawable.Drawable;
+
+import androidx.annotation.NonNull;
+import androidx.annotation.Nullable;
+
+public class WhisperGlyphDrawable extends Drawable {
+    private final WhisperGlyphRenderer.GlyphKind kind;
+    private final int fg;
+    private final int bg;
+    private final boolean showProvenance;
+    private final String hostPatp;
+    private int size = 48;
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind) {
+        this(kind, null, false);
+    }
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind, @Nullable String hostPatp, boolean showProvenance) {
+        this.kind = kind;
+        this.hostPatp = hostPatp;
+        this.showProvenance = showProvenance && hostPatp != null;
+
+        int paletteIndex;
+        if (hostPatp != null) {
+            paletteIndex = WhisperTokens.paletteIndexForPatp(hostPatp);
+        } else {
+            paletteIndex = WhisperGlyphRenderer.defaultPaletteIndex(kind);
+        }
+        this.bg = WhisperTokens.paletteBg(paletteIndex);
+        this.fg = WhisperTokens.paletteFg(paletteIndex);
+    }
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind, int fg, int bg) {
+        this.kind = kind;
+        this.fg = fg;
+        this.bg = bg;
+        this.showProvenance = false;
+        this.hostPatp = null;
+    }
+
+    @Override
+    public void draw(@NonNull Canvas canvas) {
+        int width = getBounds().width();
+        int height = getBounds().height();
+        size = Math.min(width, height);
+        if (size <= 0) size = 48;
+
+        canvas.save();
+        canvas.translate(getBounds().left, getBounds().top);
+
+        WhisperGlyphRenderer.draw(canvas, kind, size, fg, bg);
+
+        // Draw provenance dot if needed
+        if (showProvenance && hostPatp != null) {
+            int[] hostPalette = WhisperTokens.paletteForPatp(hostPatp);
+            int dotColor = hostPalette[1];  // fg color
+            float dotSize = size * 0.22f;
+            float border = size * 0.025f;
+
+            android.graphics.Paint borderPaint = new android.graphics.Paint(android.graphics.Paint.ANTI_ALIAS_FLAG);
+            borderPaint.setColor(bg);
+            borderPaint.setStyle(android.graphics.Paint.Style.FILL);
+
+            android.graphics.Paint dotPaint = new android.graphics.Paint(android.graphics.Paint.ANTI_ALIAS_FLAG);
+            dotPaint.setColor(dotColor);
+            dotPaint.setStyle(android.graphics.Paint.Style.FILL);
+
+            float right = size;
+            float bottom = size;
+            canvas.drawRect(right - dotSize - border * 2, bottom - dotSize - border * 2,
+                    right, bottom, borderPaint);
+            canvas.drawRect(right - dotSize - border, bottom - dotSize - border,
+                    right - border, bottom - border, dotPaint);
+        }
+
+        canvas.restore();
+    }
+
+    @Override
+    public void setAlpha(int alpha) {
+        // Not implemented
+    }
+
+    @Override
+    public void setColorFilter(@Nullable ColorFilter colorFilter) {
+        // Not implemented
+    }
+
+    @Override
+    public int getOpacity() {
+        return PixelFormat.OPAQUE;
+    }
+
+    @Override
+    public int getIntrinsicWidth() {
+        return size;
+    }
+
+    @Override
+    public int getIntrinsicHeight() {
+        return size;
+    }
+}
diff --git a/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java b/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java
new file mode 100644
index 0000000000..6edbe5b3e7
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java
@@ -0,0 +1,360 @@
+/*
+ * Whisper OS Glyph Renderer
+ * Draws the 24 system glyphs onto a Canvas.
+ * Port of SigilGlyphs.kt from the Compose reference implementation.
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Canvas;
+import android.graphics.Paint;
+import android.graphics.Path;
+import android.graphics.RectF;
+
+public final class WhisperGlyphRenderer {
+    private WhisperGlyphRenderer() {}
+
+    public enum GlyphKind {
+        // communication
+        MESSAGES, TALK, PHONE, MAIL, CONTACT, HARK,
+        // time + place
+        CALENDAR, CLOCK, MAPS, WEATHER,
+        // capture + media
+        CAMERA, PHOTOS, MUSIC, STUDIO,
+        // documents
+        NOTES, FILES, READ, MEMEX, WALLET,
+        // system
+        SETTINGS, BROWSER, SEARCH, DOJO, AI
+    }
+
+    public static int defaultPaletteIndex(GlyphKind kind) {
+        switch (kind) {
+            case PHONE:
+            case TALK:
+            case CONTACT:
+                return WhisperTokens.PALETTE_MINT;
+            case MESSAGES:
+            case CALENDAR:
+            case HARK:
+            case AI:
+                return WhisperTokens.PALETTE_AMBER;
+            case MAIL:
+            case WALLET:
+            case READ:
+                return WhisperTokens.PALETTE_WHEAT;
+            case CAMERA:
+            case PHOTOS:
+            case STUDIO:
+                return WhisperTokens.PALETTE_CORAL;
+            case MAPS:
+            case WEATHER:
+                return WhisperTokens.PALETTE_SKY;
+            case MUSIC:
+            case MEMEX:
+                return WhisperTokens.PALETTE_LAVENDER;
+            case FILES:
+            case NOTES:
+                return WhisperTokens.PALETTE_SAGE;
+            default:
+                return WhisperTokens.PALETTE_PAPER;  // Clock, Settings, Browser, Search, Dojo
+        }
+    }
+
+    /**
+     * Draw a glyph centered in the given bounds.
+     * The glyph is drawn on a 24-unit logical grid, scaled to fit.
+     */
+    public static void draw(Canvas canvas, GlyphKind kind, float size, int fg, int bg) {
+        float inset = size * 0.14f;
+        float viewport = size - inset * 2f;
+        float u = viewport / 24f;
+
+        Paint bgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        bgPaint.setColor(bg);
+        bgPaint.setStyle(Paint.Style.FILL);
+        canvas.drawRect(0, 0, size, size, bgPaint);
+
+        canvas.save();
+        canvas.translate(inset, inset);
+
+        Paint fgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        fgPaint.setColor(fg);
+        fgPaint.setStyle(Paint.Style.FILL);
+
+        Paint bgLinePaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        bgLinePaint.setColor(bg);
+        bgLinePaint.setStyle(Paint.Style.FILL);
+
+        switch (kind) {
+            case MESSAGES: drawMessages(canvas, fgPaint, u); break;
+            case TALK: drawTalk(canvas, fgPaint, u); break;
+            case PHONE: drawPhone(canvas, fgPaint, u); break;
+            case MAIL: drawMail(canvas, fgPaint, bgLinePaint, u); break;
+            case CONTACT: drawContact(canvas, fgPaint, u); break;
+            case HARK: drawHark(canvas, fgPaint, u); break;
+            case CALENDAR: drawCalendar(canvas, fgPaint, bgLinePaint, u); break;
+            case CLOCK: drawClock(canvas, fgPaint, bgLinePaint, u); break;
+            case MAPS: drawMaps(canvas, fgPaint, bgLinePaint, u); break;
+            case WEATHER: drawWeather(canvas, fgPaint, u); break;
+            case CAMERA: drawCamera(canvas, fgPaint, bgLinePaint, u); break;
+            case PHOTOS: drawPhotos(canvas, fgPaint, bgLinePaint, u); break;
+            case MUSIC: drawMusic(canvas, fgPaint, u); break;
+            case STUDIO: drawStudio(canvas, fgPaint, u); break;
+            case NOTES: drawNotes(canvas, fgPaint, u); break;
+            case FILES: drawFiles(canvas, fgPaint, u); break;
+            case READ: drawRead(canvas, fgPaint, bgLinePaint, u); break;
+            case MEMEX: drawMemex(canvas, fgPaint, u); break;
+            case WALLET: drawWallet(canvas, fgPaint, u); break;
+            case SETTINGS: drawSettings(canvas, fgPaint, u); break;
+            case BROWSER: drawBrowser(canvas, fgPaint, bgLinePaint, u); break;
+            case SEARCH: drawSearch(canvas, fgPaint, u); break;
+            case DOJO: drawDojo(canvas, fgPaint, u); break;
+            case AI: drawAi(canvas, fgPaint, u); break;
+        }
+
+        canvas.restore();
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Communication glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawMessages(Canvas c, Paint p, float u) {
+        Path path = new Path();
+        path.moveTo(3f * u, 5f * u);
+        path.lineTo(21f * u, 5f * u);
+        path.lineTo(21f * u, 16f * u);
+        path.lineTo(10f * u, 16f * u);
+        path.lineTo(5f * u, 20f * u);
+        path.lineTo(7f * u, 16f * u);
+        path.lineTo(3f * u, 16f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+
+    private static void drawTalk(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 12f * u, 3.5f * u, p);
+        // Left arc
+        Path left = new Path();
+        left.moveTo(5.5f * u, 5.5f * u);
+        left.quadTo(3f * u, 12f * u, 5.5f * u, 18.5f * u);
+        left.lineTo(7f * u, 18.5f * u);
+        left.quadTo(5f * u, 12f * u, 7f * u, 5.5f * u);
+        left.close();
+        c.drawPath(left, p);
+        // Right arc
+        Path right = new Path();
+        right.moveTo(18.5f * u, 5.5f * u);
+        right.quadTo(21f * u, 12f * u, 18.5f * u, 18.5f * u);
+        right.lineTo(17f * u, 18.5f * u);
+        right.quadTo(19f * u, 12f * u, 17f * u, 5.5f * u);
+        right.close();
+        c.drawPath(right, p);
+    }
+
+    private static void drawPhone(Canvas c, Paint p, float u) {
+        c.drawCircle(6.5f * u, 6.5f * u, 3f * u, p);
+        c.drawCircle(17.5f * u, 17.5f * u, 3f * u, p);
+        c.save();
+        c.rotate(-45f, 12f * u, 12f * u);
+        c.drawRect(11f * u, 2f * u, 13f * u, 22f * u, p);
+        c.restore();
+    }
+
+    private static void drawMail(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 6f * u, 21f * u, 19f * u, fg);
+        Path v = new Path();
+        v.moveTo(3f * u, 6f * u);
+        v.lineTo(12f * u, 14f * u);
+        v.lineTo(21f * u, 6f * u);
+        v.lineTo(21f * u, 8.5f * u);
+        v.lineTo(12f * u, 16.5f * u);
+        v.lineTo(3f * u, 8.5f * u);
+        v.close();
+        c.drawPath(v, bg);
+    }
+
+    private static void drawContact(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 8f * u, 4f * u, p);
+        Path body = new Path();
+        body.moveTo(3f * u, 22f * u);
+        body.quadTo(3f * u, 13f * u, 12f * u, 13f * u);
+        body.quadTo(21f * u, 13f * u, 21f * u, 22f * u);
+        body.close();
+        c.drawPath(body, p);
+    }
+
+    private static void drawHark(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 11f * u, 7f * u, p);
+        c.drawRect(9f * u, 18f * u, 15f * u, 21f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Time + place glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawCalendar(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 5f * u, 21f * u, 21f * u, fg);
+        c.drawRect(3f * u, 9f * u, 21f * u, 10.5f * u, bg);
+        c.drawRect(6f * u, 3f * u, 8f * u, 8f * u, fg);
+        c.drawRect(16f * u, 3f * u, 18f * u, 8f * u, fg);
+    }
+
+    private static void drawClock(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawCircle(12f * u, 12f * u, 9f * u, fg);
+        c.drawRect(11f * u, 5f * u, 13f * u, 13f * u, bg);
+        c.drawRect(11f * u, 11f * u, 18f * u, 13f * u, bg);
+    }
+
+    private static void drawMaps(Canvas c, Paint fg, Paint bg, float u) {
+        Path diamond = new Path();
+        diamond.moveTo(12f * u, 2f * u);
+        diamond.lineTo(21f * u, 12f * u);
+        diamond.lineTo(12f * u, 22f * u);
+        diamond.lineTo(3f * u, 12f * u);
+        diamond.close();
+        c.drawPath(diamond, fg);
+        c.drawCircle(12f * u, 10f * u, 2.5f * u, bg);
+    }
+
+    private static void drawWeather(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 12f * u, 5f * u, p);
+        // Rays
+        c.drawRect(11f * u, 2f * u, 13f * u, 5f * u, p);
+        c.drawRect(11f * u, 19f * u, 13f * u, 22f * u, p);
+        c.drawRect(2f * u, 11f * u, 5f * u, 13f * u, p);
+        c.drawRect(19f * u, 11f * u, 22f * u, 13f * u, p);
+        // Diagonal rays
+        c.save();
+        c.rotate(-45f, 5.5f * u, 6f * u);
+        c.drawRect(4.5f * u, 4.5f * u, 6.5f * u, 7.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(45f, 18.5f * u, 6f * u);
+        c.drawRect(17.5f * u, 4.5f * u, 19.5f * u, 7.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(45f, 5.5f * u, 18f * u);
+        c.drawRect(4.5f * u, 16.5f * u, 6.5f * u, 19.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(-45f, 18.5f * u, 18f * u);
+        c.drawRect(17.5f * u, 16.5f * u, 19.5f * u, 19.5f * u, p);
+        c.restore();
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Capture + media glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawCamera(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 7f * u, 21f * u, 21f * u, fg);
+        c.drawRect(8f * u, 4f * u, 16f * u, 7f * u, fg);
+        c.drawCircle(12f * u, 14f * u, 4f * u, bg);
+        c.drawCircle(12f * u, 14f * u, 1.5f * u, fg);
+    }
+
+    private static void drawPhotos(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 3f * u, 16f * u, 16f * u, fg);
+        c.drawRect(6f * u, 6f * u, 20f * u, 20f * u, bg);
+        c.drawRect(7f * u, 7f * u, 20f * u, 20f * u, fg);
+    }
+
+    private static void drawMusic(Canvas c, Paint p, float u) {
+        c.drawRect(11f * u, 4f * u, 13f * u, 18f * u, p);
+        c.drawCircle(8f * u, 17f * u, 3.5f * u, p);
+    }
+
+    private static void drawStudio(Canvas c, Paint p, float u) {
+        c.drawRect(4f * u, 4f * u, 11f * u, 11f * u, p);
+        c.drawRect(13f * u, 4f * u, 20f * u, 11f * u, p);
+        c.drawRect(4f * u, 13f * u, 11f * u, 20f * u, p);
+        c.drawRect(13f * u, 13f * u, 20f * u, 20f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Documents glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawNotes(Canvas c, Paint p, float u) {
+        Path path = new Path();
+        path.moveTo(5f * u, 4f * u);
+        path.lineTo(16f * u, 4f * u);
+        path.lineTo(20f * u, 8f * u);
+        path.lineTo(20f * u, 20f * u);
+        path.lineTo(5f * u, 20f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+
+    private static void drawFiles(Canvas c, Paint p, float u) {
+        c.drawRect(3f * u, 4f * u, 12f * u, 8f * u, p);
+        c.drawRect(3f * u, 7f * u, 21f * u, 21f * u, p);
+    }
+
+    private static void drawRead(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 5f * u, 21f * u, 19f * u, fg);
+        c.drawRect(11.5f * u, 5f * u, 12.5f * u, 19f * u, bg);
+    }
+
+    private static void drawMemex(Canvas c, Paint p, float u) {
+        c.drawRect(4f * u, 4f * u, 20f * u, 20f * u, p);
+        // Grid lines would go here in full impl
+    }
+
+    private static void drawWallet(Canvas c, Paint p, float u) {
+        c.drawRect(3f * u, 6f * u, 21f * u, 18f * u, p);
+        c.drawRect(16f * u, 10f * u, 21f * u, 14f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // System glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawSettings(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 12f * u, 4f * u, p);
+        // Gear teeth
+        for (int i = 0; i < 8; i++) {
+            c.save();
+            c.rotate(i * 45f, 12f * u, 12f * u);
+            c.drawRect(10.5f * u, 2f * u, 13.5f * u, 6f * u, p);
+            c.restore();
+        }
+    }
+
+    private static void drawBrowser(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawCircle(12f * u, 12f * u, 9f * u, fg);
+        // Horizontal line
+        c.drawRect(3f * u, 11f * u, 21f * u, 13f * u, bg);
+        // Vertical line
+        c.drawRect(11f * u, 3f * u, 13f * u, 21f * u, bg);
+    }
+
+    private static void drawSearch(Canvas c, Paint p, float u) {
+        Paint stroke = new Paint(p);
+        stroke.setStyle(Paint.Style.STROKE);
+        stroke.setStrokeWidth(2f * u);
+        c.drawCircle(10f * u, 10f * u, 5f * u, stroke);
+        c.save();
+        c.rotate(45f, 14f * u, 14f * u);
+        c.drawRect(13f * u, 14f * u, 15f * u, 21f * u, p);
+        c.restore();
+    }
+
+    private static void drawDojo(Canvas c, Paint p, float u) {
+        // Terminal prompt style
+        c.drawRect(3f * u, 10f * u, 7f * u, 14f * u, p);
+        c.drawRect(9f * u, 11f * u, 21f * u, 13f * u, p);
+    }
+
+    private static void drawAi(Canvas c, Paint p, float u) {
+        // Diamond/crystal shape
+        Path path = new Path();
+        path.moveTo(12f * u, 3f * u);
+        path.lineTo(20f * u, 10f * u);
+        path.lineTo(12f * u, 21f * u);
+        path.lineTo(4f * u, 10f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+}
diff --git a/src/com/android/launcher3/whisper/WhisperStatusStrip.java b/src/com/android/launcher3/whisper/WhisperStatusStrip.java
new file mode 100644
index 0000000000..ee3a25f514
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperStatusStrip.java
@@ -0,0 +1,170 @@
+/*
+ * Whisper OS Status Strip
+ * The signature chrome element showing runtime status.
+ * See design handoff: 01-foundations.md §1.6
+ */
+
+package com.android.launcher3.whisper;
+
+import android.content.Context;
+import android.graphics.Canvas;
+import android.graphics.Paint;
+import android.graphics.Typeface;
+import android.text.TextUtils;
+import android.util.AttributeSet;
+import android.view.View;
+
+import java.util.ArrayList;
+import java.util.List;
+
+public class WhisperStatusStrip extends View {
+
+    private final Paint bgPaint;
+    private final Paint textPaint;
+    private final Paint accentPaint;
+
+    private boolean inverted = false;
+    private String shipName = null;
+    private String runtimeState = null;
+    private String vereVersion = null;
+    private List<String> extras = new ArrayList<>();
+
+    private static final int PAD_H = 14;
+    private static final int PAD_V = 10;
+    private static final int TEXT_SIZE = 11;
+
+    public WhisperStatusStrip(Context context) {
+        this(context, null);
+    }
+
+    public WhisperStatusStrip(Context context, AttributeSet attrs) {
+        this(context, attrs, 0);
+    }
+
+    public WhisperStatusStrip(Context context, AttributeSet attrs, int defStyleAttr) {
+        super(context, attrs, defStyleAttr);
+
+        float density = context.getResources().getDisplayMetrics().density;
+
+        bgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        bgPaint.setStyle(Paint.Style.FILL);
+
+        textPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        textPaint.setTypeface(Typeface.MONOSPACE);
+        textPaint.setTextSize(TEXT_SIZE * density);
+        textPaint.setLetterSpacing(0.03f);
+
+        accentPaint = new Paint(textPaint);
+        accentPaint.setColor(WhisperTokens.ACCENT_AMBER);
+
+        updateColors();
+    }
+
+    public void setInverted(boolean inverted) {
+        if (this.inverted != inverted) {
+            this.inverted = inverted;
+            updateColors();
+            invalidate();
+        }
+    }
+
+    public void setShipName(String shipName) {
+        this.shipName = shipName;
+        invalidate();
+    }
+
+    public void setRuntimeState(String state) {
+        this.runtimeState = state;
+        invalidate();
+    }
+
+    public void setVereVersion(String version) {
+        this.vereVersion = version;
+        invalidate();
+    }
+
+    public void setExtras(List<String> extras) {
+        this.extras = extras != null ? extras : new ArrayList<>();
+        invalidate();
+    }
+
+    private void updateColors() {
+        if (inverted) {
+            bgPaint.setColor(WhisperTokens.PAPER);
+            textPaint.setColor(WhisperTokens.INK);
+        } else {
+            bgPaint.setColor(WhisperTokens.INK);
+            textPaint.setColor(WhisperTokens.PAPER);
+        }
+    }
+
+    @Override
+    protected void onMeasure(int widthMeasureSpec, int heightMeasureSpec) {
+        float density = getResources().getDisplayMetrics().density;
+        int height = getPaddingTop() + getPaddingBottom()
+                + (int) ((PAD_V * 2 + TEXT_SIZE + 4) * density);
+        int width = MeasureSpec.getSize(widthMeasureSpec);
+        setMeasuredDimension(width, height);
+    }
+
+    @Override
+    protected void onDraw(Canvas canvas) {
+        super.onDraw(canvas);
+
+        float density = getResources().getDisplayMetrics().density;
+        float padH = PAD_H * density;
+        float padV = getPaddingTop() + PAD_V * density;
+
+        // Draw background
+        canvas.drawRect(0, 0, getWidth(), getHeight(), bgPaint);
+
+        // Build status text
+        StringBuilder sb = new StringBuilder();
+
+        if (!TextUtils.isEmpty(shipName)) {
+            sb.append(shipName);
+        }
+
+        if (!TextUtils.isEmpty(runtimeState)) {
+            if (sb.length() > 0) sb.append(" · ");
+            sb.append(runtimeState);
+        }
+
+        if (!TextUtils.isEmpty(vereVersion)) {
+            if (sb.length() > 0) sb.append(" · ");
+            sb.append("v").append(vereVersion);
+        }
+
+        for (String extra : extras) {
+            if (!TextUtils.isEmpty(extra)) {
+                if (sb.length() > 0) sb.append(" · ");
+                sb.append(extra);
+            }
+        }
+
+        String statusText = sb.toString();
+        if (TextUtils.isEmpty(statusText)) {
+            statusText = "whisper os";
+        }
+
+        // Calculate baseline
+        Paint.FontMetrics fm = textPaint.getFontMetrics();
+        float baseline = padV + (-fm.top);
+
+        // Draw % accent
+        float x = padH;
+        canvas.drawText("%", x, baseline, accentPaint);
+        x += accentPaint.measureText("% ");
+
+        // Draw status text (truncate if needed)
+        float maxWidth = getWidth() - x - padH;
+        String displayText = statusText;
+        if (textPaint.measureText(displayText) > maxWidth) {
+            while (displayText.length() > 3 && textPaint.measureText(displayText + "…") > maxWidth) {
+                displayText = displayText.substring(0, displayText.length() - 1);
+            }
+            displayText = displayText + "…";
+        }
+        canvas.drawText(displayText, x, baseline, textPaint);
+    }
+}
