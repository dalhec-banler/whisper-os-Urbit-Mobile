diff --git a/src/com/android/launcher3/whisper/WhisperAppGlyphs.java b/src/com/android/launcher3/whisper/WhisperAppGlyphs.java
new file mode 100644
index 0000000000..42890545c9
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperAppGlyphs.java
@@ -0,0 +1,165 @@
+/*
+ * Whisper OS App Glyph Mapping
+ * Maps hosted app IDs and desks to appropriate glyphs.
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Bitmap;
+import android.graphics.Canvas;
+
+import androidx.annotation.Nullable;
+
+import java.util.HashMap;
+import java.util.Map;
+
+public final class WhisperAppGlyphs {
+    private WhisperAppGlyphs() {}
+
+    private static final Map<String, WhisperGlyphRenderer.GlyphKind> APP_GLYPHS = new HashMap<>();
+    private static final Map<String, WhisperGlyphRenderer.GlyphKind> DESK_GLYPHS = new HashMap<>();
+    private static final Map<String, WhisperGlyphRenderer.GlyphKind> TITLE_GLYPHS = new HashMap<>();
+    private static final Map<String, WhisperGlyphRenderer.GlyphKind> PACKAGE_GLYPHS = new HashMap<>();
+
+    static {
+        // Known app IDs
+        APP_GLYPHS.put("tlon", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        APP_GLYPHS.put("groups", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        APP_GLYPHS.put("dojo", WhisperGlyphRenderer.GlyphKind.DOJO);
+        APP_GLYPHS.put("store", WhisperGlyphRenderer.GlyphKind.FILES);
+        APP_GLYPHS.put("landscape", WhisperGlyphRenderer.GlyphKind.BROWSER);
+
+        TITLE_GLYPHS.put("app store", WhisperGlyphRenderer.GlyphKind.FILES);
+        TITLE_GLYPHS.put("auditor", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+        TITLE_GLYPHS.put("calculator", WhisperGlyphRenderer.GlyphKind.DOJO);
+        TITLE_GLYPHS.put("camera", WhisperGlyphRenderer.GlyphKind.CAMERA);
+        TITLE_GLYPHS.put("clock", WhisperGlyphRenderer.GlyphKind.CLOCK);
+        TITLE_GLYPHS.put("contacts", WhisperGlyphRenderer.GlyphKind.CONTACT);
+        TITLE_GLYPHS.put("files", WhisperGlyphRenderer.GlyphKind.FILES);
+        TITLE_GLYPHS.put("gallery", WhisperGlyphRenderer.GlyphKind.PHOTOS);
+        TITLE_GLYPHS.put("info", WhisperGlyphRenderer.GlyphKind.AI);
+        TITLE_GLYPHS.put("landscape", WhisperGlyphRenderer.GlyphKind.BROWSER);
+        TITLE_GLYPHS.put("messaging", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        TITLE_GLYPHS.put("my urbit apps", WhisperGlyphRenderer.GlyphKind.FILES);
+        TITLE_GLYPHS.put("pdf viewer", WhisperGlyphRenderer.GlyphKind.READ);
+        TITLE_GLYPHS.put("phone", WhisperGlyphRenderer.GlyphKind.PHONE);
+        TITLE_GLYPHS.put("settings", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+        TITLE_GLYPHS.put("terminal", WhisperGlyphRenderer.GlyphKind.DOJO);
+        TITLE_GLYPHS.put("tlon", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        TITLE_GLYPHS.put("vanadium", WhisperGlyphRenderer.GlyphKind.BROWSER);
+
+        PACKAGE_GLYPHS.put("app.grapheneos.apps", WhisperGlyphRenderer.GlyphKind.FILES);
+        PACKAGE_GLYPHS.put("app.attestation.auditor", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+        PACKAGE_GLYPHS.put("app.vanadium.browser", WhisperGlyphRenderer.GlyphKind.BROWSER);
+        PACKAGE_GLYPHS.put("com.android.calculator2", WhisperGlyphRenderer.GlyphKind.DOJO);
+        PACKAGE_GLYPHS.put("com.android.camera2", WhisperGlyphRenderer.GlyphKind.CAMERA);
+        PACKAGE_GLYPHS.put("com.android.contacts", WhisperGlyphRenderer.GlyphKind.CONTACT);
+        PACKAGE_GLYPHS.put("com.android.deskclock", WhisperGlyphRenderer.GlyphKind.CLOCK);
+        PACKAGE_GLYPHS.put("com.android.documentsui", WhisperGlyphRenderer.GlyphKind.FILES);
+        PACKAGE_GLYPHS.put("com.android.gallery3d", WhisperGlyphRenderer.GlyphKind.PHOTOS);
+        PACKAGE_GLYPHS.put("com.android.launcher3", WhisperGlyphRenderer.GlyphKind.FILES);
+        PACKAGE_GLYPHS.put("com.android.messaging", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        PACKAGE_GLYPHS.put("com.android.phone", WhisperGlyphRenderer.GlyphKind.PHONE);
+        PACKAGE_GLYPHS.put("com.android.settings", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+        PACKAGE_GLYPHS.put("com.android.stk", WhisperGlyphRenderer.GlyphKind.PHONE);
+        PACKAGE_GLYPHS.put("com.grapheneos.pdfviewer", WhisperGlyphRenderer.GlyphKind.READ);
+        PACKAGE_GLYPHS.put("io.nativeplanet.launcher", WhisperGlyphRenderer.GlyphKind.AI);
+        PACKAGE_GLYPHS.put("network.tlon.messenger", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+
+        // Known desk names
+        DESK_GLYPHS.put("groups", WhisperGlyphRenderer.GlyphKind.MESSAGES);
+        DESK_GLYPHS.put("talk", WhisperGlyphRenderer.GlyphKind.TALK);
+        DESK_GLYPHS.put("dojo", WhisperGlyphRenderer.GlyphKind.DOJO);
+        DESK_GLYPHS.put("landscape", WhisperGlyphRenderer.GlyphKind.BROWSER);
+        DESK_GLYPHS.put("base", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+        DESK_GLYPHS.put("webterm", WhisperGlyphRenderer.GlyphKind.DOJO);
+        DESK_GLYPHS.put("hark", WhisperGlyphRenderer.GlyphKind.HARK);
+        DESK_GLYPHS.put("settings", WhisperGlyphRenderer.GlyphKind.SETTINGS);
+    }
+
+    /**
+     * Get the glyph kind for a hosted app.
+     * Tries app ID first, then desk name.
+     */
+    @Nullable
+    public static WhisperGlyphRenderer.GlyphKind getGlyphKind(String appId, String desk) {
+        if (appId != null && APP_GLYPHS.containsKey(appId.toLowerCase())) {
+            return APP_GLYPHS.get(appId.toLowerCase());
+        }
+        if (desk != null) {
+            String deskName = desk.toLowerCase().replace("%", "").trim();
+            if (DESK_GLYPHS.containsKey(deskName)) {
+                return DESK_GLYPHS.get(deskName);
+            }
+        }
+        return null;
+    }
+
+    @Nullable
+    public static WhisperGlyphRenderer.GlyphKind getGlyphKindForLauncherItem(
+            @Nullable CharSequence title, @Nullable String packageName) {
+        if (title != null) {
+            WhisperGlyphRenderer.GlyphKind kind =
+                    TITLE_GLYPHS.get(title.toString().toLowerCase().trim());
+            if (kind != null) {
+                return kind;
+            }
+        }
+        if (packageName != null) {
+            WhisperGlyphRenderer.GlyphKind kind = PACKAGE_GLYPHS.get(packageName.toLowerCase());
+            if (kind != null) {
+                return kind;
+            }
+            if (packageName.startsWith("network.tlon.")) {
+                return WhisperGlyphRenderer.GlyphKind.MESSAGES;
+            }
+            if (packageName.startsWith("io.nativeplanet.")
+                    || packageName.startsWith("org.urbit.")) {
+                return WhisperGlyphRenderer.GlyphKind.AI;
+            }
+            if (packageName.startsWith("com.google.android.apps.photos")) {
+                return WhisperGlyphRenderer.GlyphKind.PHOTOS;
+            }
+        }
+        return null;
+    }
+
+    /**
+     * Create a bitmap icon for a hosted app.
+     * If no specific glyph is found, falls back to AI glyph.
+     */
+    public static Bitmap createIcon(String appId, String desk, @Nullable String hostPatp, int size) {
+        WhisperGlyphRenderer.GlyphKind kind = getGlyphKind(appId, desk);
+        if (kind == null) {
+            kind = WhisperGlyphRenderer.GlyphKind.AI;  // fallback
+        }
+
+        int paletteIndex;
+        if (hostPatp != null) {
+            paletteIndex = WhisperTokens.paletteIndexForPatp(hostPatp);
+        } else {
+            paletteIndex = WhisperGlyphRenderer.defaultPaletteIndex(kind);
+        }
+        int bg = WhisperTokens.paletteBg(paletteIndex);
+        int fg = WhisperTokens.paletteFg(paletteIndex);
+
+        Bitmap bitmap = Bitmap.createBitmap(size, size, Bitmap.Config.ARGB_8888);
+        Canvas canvas = new Canvas(bitmap);
+        WhisperGlyphRenderer.draw(canvas, kind, size, fg, bg);
+        return bitmap;
+    }
+
+    /**
+     * Create a bitmap icon for a system glyph.
+     */
+    public static Bitmap createSystemIcon(WhisperGlyphRenderer.GlyphKind kind, int size) {
+        int paletteIndex = WhisperGlyphRenderer.defaultPaletteIndex(kind);
+        int bg = WhisperTokens.paletteBg(paletteIndex);
+        int fg = WhisperTokens.paletteFg(paletteIndex);
+
+        Bitmap bitmap = Bitmap.createBitmap(size, size, Bitmap.Config.ARGB_8888);
+        Canvas canvas = new Canvas(bitmap);
+        WhisperGlyphRenderer.draw(canvas, kind, size, fg, bg);
+        return bitmap;
+    }
+}
diff --git a/src/com/android/launcher3/whisper/WhisperGlyphDrawable.java b/src/com/android/launcher3/whisper/WhisperGlyphDrawable.java
new file mode 100644
index 0000000000..25313f1761
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperGlyphDrawable.java
@@ -0,0 +1,114 @@
+/*
+ * Whisper OS Glyph Drawable
+ * A Drawable that renders a Whisper glyph using WhisperGlyphRenderer.
+ * Can be used anywhere a Drawable is expected (ImageView, icon, etc.)
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Canvas;
+import android.graphics.ColorFilter;
+import android.graphics.PixelFormat;
+import android.graphics.drawable.Drawable;
+
+import androidx.annotation.NonNull;
+import androidx.annotation.Nullable;
+
+public class WhisperGlyphDrawable extends Drawable {
+    private final WhisperGlyphRenderer.GlyphKind kind;
+    private final int fg;
+    private final int bg;
+    private final boolean showProvenance;
+    private final String hostPatp;
+    private int size = 48;
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind) {
+        this(kind, null, false);
+    }
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind, @Nullable String hostPatp, boolean showProvenance) {
+        this.kind = kind;
+        this.hostPatp = hostPatp;
+        this.showProvenance = showProvenance && hostPatp != null;
+
+        int paletteIndex;
+        if (hostPatp != null) {
+            paletteIndex = WhisperTokens.paletteIndexForPatp(hostPatp);
+        } else {
+            paletteIndex = WhisperGlyphRenderer.defaultPaletteIndex(kind);
+        }
+        this.bg = WhisperTokens.paletteBg(paletteIndex);
+        this.fg = WhisperTokens.paletteFg(paletteIndex);
+    }
+
+    public WhisperGlyphDrawable(WhisperGlyphRenderer.GlyphKind kind, int fg, int bg) {
+        this.kind = kind;
+        this.fg = fg;
+        this.bg = bg;
+        this.showProvenance = false;
+        this.hostPatp = null;
+    }
+
+    @Override
+    public void draw(@NonNull Canvas canvas) {
+        int width = getBounds().width();
+        int height = getBounds().height();
+        size = Math.min(width, height);
+        if (size <= 0) size = 48;
+
+        canvas.save();
+        canvas.translate(getBounds().left, getBounds().top);
+
+        WhisperGlyphRenderer.draw(canvas, kind, size, fg, bg);
+
+        // Draw provenance dot if needed
+        if (showProvenance && hostPatp != null) {
+            int[] hostPalette = WhisperTokens.paletteForPatp(hostPatp);
+            int dotColor = hostPalette[1];  // fg color
+            float dotSize = size * 0.22f;
+            float border = size * 0.025f;
+
+            android.graphics.Paint borderPaint = new android.graphics.Paint(android.graphics.Paint.ANTI_ALIAS_FLAG);
+            borderPaint.setColor(bg);
+            borderPaint.setStyle(android.graphics.Paint.Style.FILL);
+
+            android.graphics.Paint dotPaint = new android.graphics.Paint(android.graphics.Paint.ANTI_ALIAS_FLAG);
+            dotPaint.setColor(dotColor);
+            dotPaint.setStyle(android.graphics.Paint.Style.FILL);
+
+            float right = size;
+            float bottom = size;
+            canvas.drawRect(right - dotSize - border * 2, bottom - dotSize - border * 2,
+                    right, bottom, borderPaint);
+            canvas.drawRect(right - dotSize - border, bottom - dotSize - border,
+                    right - border, bottom - border, dotPaint);
+        }
+
+        canvas.restore();
+    }
+
+    @Override
+    public void setAlpha(int alpha) {
+        // Not implemented
+    }
+
+    @Override
+    public void setColorFilter(@Nullable ColorFilter colorFilter) {
+        // Not implemented
+    }
+
+    @Override
+    public int getOpacity() {
+        return PixelFormat.OPAQUE;
+    }
+
+    @Override
+    public int getIntrinsicWidth() {
+        return size;
+    }
+
+    @Override
+    public int getIntrinsicHeight() {
+        return size;
+    }
+}
diff --git a/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java b/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java
new file mode 100644
index 0000000000..c710c2f817
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperGlyphRenderer.java
@@ -0,0 +1,373 @@
+/*
+ * Whisper OS Glyph Renderer
+ * Draws the 24 system glyphs onto a Canvas.
+ * Port of SigilGlyphs.kt from the Compose reference implementation.
+ */
+
+package com.android.launcher3.whisper;
+
+import android.graphics.Canvas;
+import android.graphics.Paint;
+import android.graphics.Path;
+import android.graphics.RectF;
+
+public final class WhisperGlyphRenderer {
+    private WhisperGlyphRenderer() {}
+
+    public enum GlyphKind {
+        // communication
+        MESSAGES, TALK, PHONE, MAIL, CONTACT, HARK,
+        // time + place
+        CALENDAR, CLOCK, MAPS, WEATHER,
+        // capture + media
+        CAMERA, PHOTOS, MUSIC, STUDIO,
+        // documents
+        NOTES, FILES, READ, MEMEX, WALLET,
+        // system
+        SETTINGS, BROWSER, SEARCH, DOJO, AI
+    }
+
+    public static int defaultPaletteIndex(GlyphKind kind) {
+        switch (kind) {
+            case PHONE:
+            case TALK:
+            case CONTACT:
+                return WhisperTokens.PALETTE_MINT;
+            case MESSAGES:
+            case CALENDAR:
+            case HARK:
+            case AI:
+                return WhisperTokens.PALETTE_AMBER;
+            case MAIL:
+            case WALLET:
+            case READ:
+                return WhisperTokens.PALETTE_WHEAT;
+            case CAMERA:
+            case PHOTOS:
+            case STUDIO:
+                return WhisperTokens.PALETTE_CORAL;
+            case MAPS:
+            case WEATHER:
+                return WhisperTokens.PALETTE_SKY;
+            case MUSIC:
+            case MEMEX:
+                return WhisperTokens.PALETTE_LAVENDER;
+            case FILES:
+            case NOTES:
+                return WhisperTokens.PALETTE_SAGE;
+            default:
+                return WhisperTokens.PALETTE_PAPER;  // Clock, Settings, Browser, Search, Dojo
+        }
+    }
+
+    /**
+     * Draw a glyph centered in the given bounds.
+     * The glyph is drawn on a 24-unit logical grid, scaled to fit.
+     */
+    public static void draw(Canvas canvas, GlyphKind kind, float size, int fg, int bg) {
+        float inset = size * 0.14f;
+        float viewport = size - inset * 2f;
+        float u = viewport / 24f;
+
+        Paint bgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        bgPaint.setColor(bg);
+        bgPaint.setStyle(Paint.Style.FILL);
+        canvas.drawRect(0, 0, size, size, bgPaint);
+
+        canvas.save();
+        canvas.translate(inset, inset);
+
+        Paint fgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        fgPaint.setColor(fg);
+        fgPaint.setStyle(Paint.Style.FILL);
+
+        Paint bgLinePaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+        bgLinePaint.setColor(bg);
+        bgLinePaint.setStyle(Paint.Style.FILL);
+
+        switch (kind) {
+            case MESSAGES: drawMessages(canvas, fgPaint, u); break;
+            case TALK: drawTalk(canvas, fgPaint, u); break;
+            case PHONE: drawPhone(canvas, fgPaint, u); break;
+            case MAIL: drawMail(canvas, fgPaint, bgLinePaint, u); break;
+            case CONTACT: drawContact(canvas, fgPaint, u); break;
+            case HARK: drawHark(canvas, fgPaint, u); break;
+            case CALENDAR: drawCalendar(canvas, fgPaint, bgLinePaint, u); break;
+            case CLOCK: drawClock(canvas, fgPaint, bgLinePaint, u); break;
+            case MAPS: drawMaps(canvas, fgPaint, bgLinePaint, u); break;
+            case WEATHER: drawWeather(canvas, fgPaint, u); break;
+            case CAMERA: drawCamera(canvas, fgPaint, bgLinePaint, u); break;
+            case PHOTOS: drawPhotos(canvas, fgPaint, bgLinePaint, u); break;
+            case MUSIC: drawMusic(canvas, fgPaint, u); break;
+            case STUDIO: drawStudio(canvas, fgPaint, u); break;
+            case NOTES: drawNotes(canvas, fgPaint, u); break;
+            case FILES: drawFiles(canvas, fgPaint, u); break;
+            case READ: drawRead(canvas, fgPaint, bgLinePaint, u); break;
+            case MEMEX: drawMemex(canvas, fgPaint, u); break;
+            case WALLET: drawWallet(canvas, fgPaint, u); break;
+            case SETTINGS: drawSettings(canvas, fgPaint, u); break;
+            case BROWSER: drawBrowser(canvas, fgPaint, bgLinePaint, u); break;
+            case SEARCH: drawSearch(canvas, fgPaint, u); break;
+            case DOJO: drawDojo(canvas, fgPaint, u); break;
+            case AI: drawAi(canvas, fgPaint, u); break;
+        }
+
+        canvas.restore();
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Communication glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawMessages(Canvas c, Paint p, float u) {
+        Path path = new Path();
+        path.moveTo(3f * u, 5f * u);
+        path.lineTo(21f * u, 5f * u);
+        path.lineTo(21f * u, 16f * u);
+        path.lineTo(10f * u, 16f * u);
+        path.lineTo(5f * u, 20f * u);
+        path.lineTo(7f * u, 16f * u);
+        path.lineTo(3f * u, 16f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+
+    private static void drawTalk(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 12f * u, 3.5f * u, p);
+        // Left arc
+        Path left = new Path();
+        left.moveTo(5.5f * u, 5.5f * u);
+        left.quadTo(3f * u, 12f * u, 5.5f * u, 18.5f * u);
+        left.lineTo(7f * u, 18.5f * u);
+        left.quadTo(5f * u, 12f * u, 7f * u, 5.5f * u);
+        left.close();
+        c.drawPath(left, p);
+        // Right arc
+        Path right = new Path();
+        right.moveTo(18.5f * u, 5.5f * u);
+        right.quadTo(21f * u, 12f * u, 18.5f * u, 18.5f * u);
+        right.lineTo(17f * u, 18.5f * u);
+        right.quadTo(19f * u, 12f * u, 17f * u, 5.5f * u);
+        right.close();
+        c.drawPath(right, p);
+    }
+
+    private static void drawPhone(Canvas c, Paint p, float u) {
+        c.drawCircle(6.5f * u, 6.5f * u, 3f * u, p);
+        c.drawCircle(17.5f * u, 17.5f * u, 3f * u, p);
+        c.save();
+        c.rotate(-45f, 12f * u, 12f * u);
+        c.drawRect(11f * u, 2f * u, 13f * u, 22f * u, p);
+        c.restore();
+    }
+
+    private static void drawMail(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 6f * u, 21f * u, 19f * u, fg);
+        Path v = new Path();
+        v.moveTo(3f * u, 6f * u);
+        v.lineTo(12f * u, 14f * u);
+        v.lineTo(21f * u, 6f * u);
+        v.lineTo(21f * u, 8.5f * u);
+        v.lineTo(12f * u, 16.5f * u);
+        v.lineTo(3f * u, 8.5f * u);
+        v.close();
+        c.drawPath(v, bg);
+    }
+
+    private static void drawContact(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 8f * u, 4f * u, p);
+        Path body = new Path();
+        body.moveTo(3f * u, 22f * u);
+        body.quadTo(3f * u, 13f * u, 12f * u, 13f * u);
+        body.quadTo(21f * u, 13f * u, 21f * u, 22f * u);
+        body.close();
+        c.drawPath(body, p);
+    }
+
+    private static void drawHark(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 11f * u, 7f * u, p);
+        c.drawRect(9f * u, 18f * u, 15f * u, 21f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Time + place glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawCalendar(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 5f * u, 21f * u, 21f * u, fg);
+        c.drawRect(3f * u, 9f * u, 21f * u, 10.5f * u, bg);
+        c.drawRect(6f * u, 3f * u, 8f * u, 8f * u, fg);
+        c.drawRect(16f * u, 3f * u, 18f * u, 8f * u, fg);
+    }
+
+    private static void drawClock(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawCircle(12f * u, 12f * u, 9f * u, fg);
+        c.drawRect(11f * u, 5f * u, 13f * u, 13f * u, bg);
+        c.drawRect(11f * u, 11f * u, 18f * u, 13f * u, bg);
+    }
+
+    private static void drawMaps(Canvas c, Paint fg, Paint bg, float u) {
+        Path diamond = new Path();
+        diamond.moveTo(12f * u, 2f * u);
+        diamond.lineTo(21f * u, 12f * u);
+        diamond.lineTo(12f * u, 22f * u);
+        diamond.lineTo(3f * u, 12f * u);
+        diamond.close();
+        c.drawPath(diamond, fg);
+        c.drawCircle(12f * u, 10f * u, 2.5f * u, bg);
+    }
+
+    private static void drawWeather(Canvas c, Paint p, float u) {
+        c.drawCircle(12f * u, 12f * u, 5f * u, p);
+        // Rays
+        c.drawRect(11f * u, 2f * u, 13f * u, 5f * u, p);
+        c.drawRect(11f * u, 19f * u, 13f * u, 22f * u, p);
+        c.drawRect(2f * u, 11f * u, 5f * u, 13f * u, p);
+        c.drawRect(19f * u, 11f * u, 22f * u, 13f * u, p);
+        // Diagonal rays
+        c.save();
+        c.rotate(-45f, 5.5f * u, 6f * u);
+        c.drawRect(4.5f * u, 4.5f * u, 6.5f * u, 7.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(45f, 18.5f * u, 6f * u);
+        c.drawRect(17.5f * u, 4.5f * u, 19.5f * u, 7.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(45f, 5.5f * u, 18f * u);
+        c.drawRect(4.5f * u, 16.5f * u, 6.5f * u, 19.5f * u, p);
+        c.restore();
+        c.save();
+        c.rotate(-45f, 18.5f * u, 18f * u);
+        c.drawRect(17.5f * u, 16.5f * u, 19.5f * u, 19.5f * u, p);
+        c.restore();
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Capture + media glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawCamera(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 7f * u, 21f * u, 21f * u, fg);
+        c.drawRect(8f * u, 4f * u, 16f * u, 7f * u, fg);
+        c.drawCircle(12f * u, 14f * u, 4f * u, bg);
+        c.drawCircle(12f * u, 14f * u, 1.5f * u, fg);
+    }
+
+    private static void drawPhotos(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 3f * u, 16f * u, 16f * u, fg);
+        c.drawRect(6f * u, 6f * u, 20f * u, 20f * u, bg);
+        c.drawRect(7f * u, 7f * u, 20f * u, 20f * u, fg);
+    }
+
+    private static void drawMusic(Canvas c, Paint p, float u) {
+        c.drawRect(11f * u, 4f * u, 13f * u, 18f * u, p);
+        c.drawCircle(8f * u, 17f * u, 3.5f * u, p);
+    }
+
+    private static void drawStudio(Canvas c, Paint p, float u) {
+        c.drawRect(4f * u, 4f * u, 11f * u, 11f * u, p);
+        c.drawRect(13f * u, 4f * u, 20f * u, 11f * u, p);
+        c.drawRect(4f * u, 13f * u, 11f * u, 20f * u, p);
+        c.drawRect(13f * u, 13f * u, 20f * u, 20f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // Documents glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawNotes(Canvas c, Paint p, float u) {
+        Path path = new Path();
+        path.moveTo(5f * u, 4f * u);
+        path.lineTo(16f * u, 4f * u);
+        path.lineTo(20f * u, 8f * u);
+        path.lineTo(20f * u, 20f * u);
+        path.lineTo(5f * u, 20f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+
+    private static void drawFiles(Canvas c, Paint p, float u) {
+        c.drawRect(3f * u, 4f * u, 12f * u, 8f * u, p);
+        c.drawRect(3f * u, 7f * u, 21f * u, 21f * u, p);
+    }
+
+    private static void drawRead(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawRect(3f * u, 5f * u, 21f * u, 19f * u, fg);
+        c.drawRect(11.5f * u, 5f * u, 12.5f * u, 19f * u, bg);
+    }
+
+    private static void drawMemex(Canvas c, Paint p, float u) {
+        c.drawRect(4f * u, 6f * u, 17f * u, 8f * u, p);
+        c.drawRect(4f * u, 11f * u, 20f * u, 13f * u, p);
+        c.drawRect(4f * u, 16f * u, 14f * u, 18f * u, p);
+        c.drawRect(18f * u, 6f * u, 20f * u, 8f * u, p);
+    }
+
+    private static void drawWallet(Canvas c, Paint p, float u) {
+        c.drawRect(3f * u, 6f * u, 21f * u, 11f * u, p);
+        c.drawRect(3f * u, 13f * u, 21f * u, 18f * u, p);
+    }
+
+    // ─────────────────────────────────────────────────────────────
+    // System glyphs
+    // ─────────────────────────────────────────────────────────────
+
+    private static void drawSettings(Canvas c, Paint p, float u) {
+        c.drawRect(11f * u, 3f * u, 13f * u, 21f * u, p);
+        c.drawRect(3f * u, 11f * u, 21f * u, 13f * u, p);
+        c.save();
+        c.rotate(45f, 12f * u, 12f * u);
+        c.drawRect(11f * u, 3f * u, 13f * u, 21f * u, p);
+        c.drawRect(3f * u, 11f * u, 21f * u, 13f * u, p);
+        c.restore();
+    }
+
+    private static void drawBrowser(Canvas c, Paint fg, Paint bg, float u) {
+        c.drawCircle(12f * u, 12f * u, 9f * u, fg);
+        c.drawRect(3f * u, 11f * u, 21f * u, 13f * u, bg);
+        Paint stroke = new Paint(bg);
+        stroke.setStyle(Paint.Style.STROKE);
+        stroke.setStrokeWidth(2f * u);
+        c.drawOval(new RectF(8f * u, 3f * u, 16f * u, 21f * u), stroke);
+    }
+
+    private static void drawSearch(Canvas c, Paint p, float u) {
+        Paint stroke = new Paint(p);
+        stroke.setStyle(Paint.Style.STROKE);
+        stroke.setStrokeWidth(3f * u);
+        c.drawCircle(10f * u, 10f * u, 6f * u, stroke);
+        c.save();
+        c.rotate(-45f, 15.5f * u, 18f * u);
+        c.drawRect(14f * u, 14f * u, 17f * u, 22f * u, p);
+        c.restore();
+    }
+
+    private static void drawDojo(Canvas c, Paint p, float u) {
+        Paint stroke = new Paint(p);
+        stroke.setStyle(Paint.Style.STROKE);
+        stroke.setStrokeWidth(2.5f * u);
+        stroke.setStrokeCap(Paint.Cap.SQUARE);
+        stroke.setStrokeJoin(Paint.Join.MITER);
+        Path chevron = new Path();
+        chevron.moveTo(4f * u, 6f * u);
+        chevron.lineTo(11f * u, 12f * u);
+        chevron.lineTo(4f * u, 18f * u);
+        c.drawPath(chevron, stroke);
+        c.drawRect(12f * u, 17f * u, 21f * u, 19f * u, p);
+    }
+
+    private static void drawAi(Canvas c, Paint p, float u) {
+        Path path = new Path();
+        path.moveTo(12f * u, 2f * u);
+        path.lineTo(13.5f * u, 10.5f * u);
+        path.lineTo(22f * u, 12f * u);
+        path.lineTo(13.5f * u, 13.5f * u);
+        path.lineTo(12f * u, 22f * u);
+        path.lineTo(10.5f * u, 13.5f * u);
+        path.lineTo(2f * u, 12f * u);
+        path.lineTo(10.5f * u, 10.5f * u);
+        path.close();
+        c.drawPath(path, p);
+    }
+}
diff --git a/src/com/android/launcher3/whisper/WhisperHomeChromeView.java b/src/com/android/launcher3/whisper/WhisperHomeChromeView.java
new file mode 100644
index 0000000000..9ffc999355
--- /dev/null
+++ b/src/com/android/launcher3/whisper/WhisperHomeChromeView.java
@@ -0,0 +1,303 @@
+/*
+ * Whisper OS home chrome for Launcher3.
+ *
+ * This is intentionally draw-only: Launcher3 keeps native workspace paging,
+ * drag/drop, folders, and all apps gestures.
+ *
+ * Design notes (see handoff 05-surfaces-refined.md §5.1):
+ * - Status strip: ink bg, paper text, amber %
+ * - Section labels: "── SYSTEM" and "── HOSTED" as chrome (non-interactive)
+ * - Find/ask bar: rounded 16dp, amber dot + AI glyph (bottom)
+ *
+ * LIMITATION: Section labels are decorative chrome only. They cannot be tied
+ * to actual workspace item positions since Launcher3 manages placement natively.
+ */
+
+package com.android.launcher3.whisper;
+
+import android.content.Context;
+import android.graphics.Canvas;
+import android.graphics.Paint;
+import android.graphics.RectF;
+import android.graphics.Typeface;
+import android.text.TextUtils;
+import android.util.AttributeSet;
+import android.view.View;
+
+import com.android.launcher3.R;
+
+import java.text.SimpleDateFormat;
+import java.util.Date;
+import java.util.Locale;
+
+public class WhisperHomeChromeView extends View {
+    private static final long TICK_MS = 30_000L;
+
+    private final Paint backgroundPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint stripBgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint stripTextPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint amberPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint inkPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint inkDimPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint inkFaintPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint inkHairPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint clockPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint sectionPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint findBarBgPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Paint findBarTextPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+    private final Runnable tick = new Runnable() {
+        @Override
+        public void run() {
+            invalidate();
+            postDelayed(this, TICK_MS);
+        }
+    };
+
+    private Typeface serif;
+    private Typeface sans;
+    private Typeface mono;
+
+    public WhisperHomeChromeView(Context context) {
+        this(context, null);
+    }
+
+    public WhisperHomeChromeView(Context context, AttributeSet attrs) {
+        this(context, attrs, 0);
+    }
+
+    public WhisperHomeChromeView(Context context, AttributeSet attrs, int defStyleAttr) {
+        super(context, attrs, defStyleAttr);
+        setWillNotDraw(false);
+        setClickable(false);
+        setFocusable(false);
+        loadTypefaces(context);
+        setupPaints();
+    }
+
+    private void loadTypefaces(Context context) {
+        serif = Typeface.create(Typeface.SERIF, Typeface.NORMAL);
+        sans = Typeface.create(Typeface.SANS_SERIF, Typeface.NORMAL);
+        mono = Typeface.create(Typeface.MONOSPACE, Typeface.NORMAL);
+        try {
+            serif = context.getResources().getFont(R.font.source_serif_variable);
+            sans = context.getResources().getFont(R.font.inter_variable);
+            mono = context.getResources().getFont(R.font.jetbrains_mono_variable);
+        } catch (RuntimeException ignored) {
+            // Keep platform fallbacks if a font resource is unavailable in a partial build.
+        }
+    }
+
+    private void setupPaints() {
+        backgroundPaint.setColor(WhisperTokens.PAPER);
+
+        // Status strip: INK background, PAPER text (§1.6)
+        stripBgPaint.setColor(WhisperTokens.INK);
+        stripTextPaint.setColor(WhisperTokens.PAPER);
+        stripTextPaint.setTypeface(mono);
+        stripTextPaint.setTextSize(sp(11));
+        stripTextPaint.setLetterSpacing(0.03f);
+
+        amberPaint.setColor(WhisperTokens.ACCENT_AMBER);
+        amberPaint.setTypeface(mono);
+        amberPaint.setTextSize(sp(11));
+        amberPaint.setLetterSpacing(0.03f);
+
+        inkPaint.setColor(WhisperTokens.INK);
+        inkDimPaint.setColor(WhisperTokens.INK_DIM);
+        inkFaintPaint.setColor(WhisperTokens.INK_FAINT);
+
+        inkHairPaint.setColor(WhisperTokens.INK_HAIR);
+        inkHairPaint.setStyle(Paint.Style.STROKE);
+        inkHairPaint.setStrokeWidth(dp(1));
+
+        clockPaint.setColor(WhisperTokens.INK);
+        clockPaint.setTypeface(Typeface.create(serif, 300, false));
+        clockPaint.setTextSize(sp(44));
+        clockPaint.setLetterSpacing(0f);
+
+        sectionPaint.setColor(WhisperTokens.INK_FAINT);
+        sectionPaint.setTypeface(mono);
+        sectionPaint.setTextSize(sp(11));
+        sectionPaint.setLetterSpacing(0.15f);
+
+        // Find bar: 6% ink overlay on paper (§1.7, §5.1)
+        findBarBgPaint.setColor(0x0F1A1916);  // 6% ink
+        findBarTextPaint.setColor(WhisperTokens.INK_DIM);
+        findBarTextPaint.setTypeface(sans);
+        findBarTextPaint.setTextSize(sp(13));
+    }
+
+    @Override
+    protected void onAttachedToWindow() {
+        super.onAttachedToWindow();
+        removeCallbacks(tick);
+        post(tick);
+    }
+
+    @Override
+    protected void onDetachedFromWindow() {
+        removeCallbacks(tick);
+        super.onDetachedFromWindow();
+    }
+
+    @Override
+    protected void onDraw(Canvas canvas) {
+        super.onDraw(canvas);
+        canvas.drawRect(0, 0, getWidth(), getHeight(), backgroundPaint);
+        drawStatusStrip(canvas);
+        drawClock(canvas);
+        drawSectionLabels(canvas);
+        drawFindAskBar(canvas);
+    }
+
+    /**
+     * Status strip: ink background, paper text, amber % (§1.6)
+     */
+    private void drawStatusStrip(Canvas canvas) {
+        float stripH = dp(34);
+        // INK background (corrected from paper)
+        canvas.drawRect(0, 0, getWidth(), stripH, stripBgPaint);
+
+        String status = "whisper os";
+        float x = dp(14);
+        float baseline = dp(22);
+
+        // Amber % symbol
+        canvas.drawText("%", x, baseline, amberPaint);
+        x += amberPaint.measureText("% ");
+
+        // Paper text for status
+        canvas.drawText(status, x, baseline, stripTextPaint);
+    }
+
+    /**
+     * Clock: serif 44, ink (§5.1)
+     */
+    private void drawClock(Canvas canvas) {
+        Date now = new Date();
+        String time = new SimpleDateFormat("h:mm", Locale.US).format(now);
+        // Format: "TUE · MAY 6" - uppercase with mid-dot separator
+        String dayPart = new SimpleDateFormat("EEE", Locale.US).format(now).toUpperCase(Locale.US);
+        String datePart = new SimpleDateFormat("MMM d", Locale.US).format(now).toUpperCase(Locale.US);
+        String dateStr = dayPart + " · " + datePart;
+
+        float left = dp(22);  // screenPadX
+        float top = dp(78);
+        canvas.drawText(time, left, top, clockPaint);
+
+        // Date in mono, inkDim
+        inkDimPaint.setTypeface(mono);
+        inkDimPaint.setTextSize(sp(11));
+        inkDimPaint.setLetterSpacing(0.03f);
+        canvas.drawText(dateStr, left, top + dp(22), inkDimPaint);
+    }
+
+    /**
+     * Decorative home section labels from §5.1. Launcher3 still owns item placement; these labels
+     * are non-interactive chrome behind the native workspace.
+     */
+    private void drawSectionLabels(Canvas canvas) {
+        float left = dp(22);
+        canvas.drawText("── SYSTEM", left, dp(136), sectionPaint);
+        canvas.drawText("── HOSTED", left, dp(346), sectionPaint);
+    }
+
+    /**
+     * Find/ask bar: rounded 16dp, amber dot + AI glyph (§5.1, §5.9)
+     * The only rounded element on the home surface.
+     * Positioned above the dock (hotseat) area.
+     */
+    private void drawFindAskBar(Canvas canvas) {
+        float barH = dp(48);
+        float barMarginX = dp(22);  // screenPadX
+        // Position above the dock - dock is ~100dp from bottom including nav gestures
+        float barMarginBottom = dp(110);
+        float barRadius = dp(16);
+
+        float left = barMarginX;
+        float right = getWidth() - barMarginX;
+        float bottom = getHeight() - barMarginBottom;
+        float top = bottom - barH;
+
+        RectF barRect = new RectF(left, top, right, bottom);
+        canvas.drawRoundRect(barRect, barRadius, barRadius, findBarBgPaint);
+
+        // Amber dot (5dp)
+        float dotSize = dp(5);
+        float dotX = left + dp(16);
+        float dotY = top + barH / 2;
+        amberPaint.setStyle(Paint.Style.FILL);
+        canvas.drawRect(dotX - dotSize/2, dotY - dotSize/2,
+                        dotX + dotSize/2, dotY + dotSize/2, amberPaint);
+
+        // Text: "find an app, or ask…"
+        String text = "find an app, or ask…";
+        float textX = dotX + dp(12);
+        Paint.FontMetrics fm = findBarTextPaint.getFontMetrics();
+        float textY = top + (barH - fm.bottom + fm.top) / 2 - fm.top;
+        canvas.drawText(text, textX, textY, findBarTextPaint);
+
+        // AI glyph placeholder (draw a small spark shape on right side)
+        // Full glyph rendering would use WhisperGlyphRenderer
+        float glyphSize = dp(22);
+        float glyphRight = right - dp(16);
+        float glyphCenterX = glyphRight - glyphSize/2;
+        float glyphCenterY = top + barH/2;
+
+        // Simple 4-point spark shape for AI glyph
+        amberPaint.setStyle(Paint.Style.FILL);
+        float s = glyphSize * 0.4f;  // spark arm length
+        float c = glyphSize * 0.12f; // center thickness
+        // Draw 4 triangular arms
+        drawSparkArm(canvas, glyphCenterX, glyphCenterY, 0, s, c);    // up
+        drawSparkArm(canvas, glyphCenterX, glyphCenterY, 90, s, c);   // right
+        drawSparkArm(canvas, glyphCenterX, glyphCenterY, 180, s, c);  // down
+        drawSparkArm(canvas, glyphCenterX, glyphCenterY, 270, s, c);  // left
+    }
+
+    private void drawSparkArm(Canvas canvas, float cx, float cy, float angleDeg,
+                               float length, float thickness) {
+        double rad = Math.toRadians(angleDeg);
+        float dx = (float) Math.sin(rad);
+        float dy = (float) -Math.cos(rad);
+        float px = (float) Math.cos(rad);
+        float py = (float) Math.sin(rad);
+
+        float tipX = cx + dx * length;
+        float tipY = cy + dy * length;
+        float baseX1 = cx + px * thickness;
+        float baseY1 = cy + py * thickness;
+        float baseX2 = cx - px * thickness;
+        float baseY2 = cy - py * thickness;
+
+        android.graphics.Path path = new android.graphics.Path();
+        path.moveTo(tipX, tipY);
+        path.lineTo(baseX1, baseY1);
+        path.lineTo(baseX2, baseY2);
+        path.close();
+        canvas.drawPath(path, amberPaint);
+    }
+
+    private void drawEllipsized(Canvas canvas, String text, float x, float baseline,
+            float maxWidth, Paint paint) {
+        if (TextUtils.isEmpty(text)) {
+            return;
+        }
+        String out = text;
+        while (out.length() > 1 && paint.measureText(out) > maxWidth) {
+            out = out.substring(0, out.length() - 1);
+        }
+        if (!out.equals(text) && out.length() > 1) {
+            out = out.substring(0, out.length() - 1) + "…";
+        }
+        canvas.drawText(out, x, baseline, paint);
+    }
+
+    private float dp(float value) {
+        return value * getResources().getDisplayMetrics().density;
+    }
+
+    private float sp(float value) {
+        return value * getResources().getDisplayMetrics().scaledDensity;
+    }
+}
