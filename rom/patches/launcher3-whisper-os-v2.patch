+
+    private static Intent createHostedLaunchIntent(Context context, HostedApp app) {
+        return new Intent(ACTION_OPEN_URBIT_APP)
+                .setClass(context, WhisperHostedAppsActivity.class)
+                .putExtra("id", app.id)
+                .putExtra("title", app.title)
+                .putExtra("desk", app.desk)
+                .putExtra("launchMode", app.launchMode)
