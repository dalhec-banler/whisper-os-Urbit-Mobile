+    }
+
+    private TextView text(String value, int sp, int color, int style, Typeface family) {
+        TextView view = new TextView(this);
+        view.setText(value);
+        view.setTextSize(sp);
+        view.setTextColor(color);
+        view.setIncludeFontPadding(true);
+        view.setTypeface(family, style);
+        return view;
+    }
+
+    private GradientDrawable box(int fill, int stroke, int radius) {
+        GradientDrawable drawable = new GradientDrawable();
+        drawable.setColor(fill);
+        drawable.setCornerRadius(radius);
+        drawable.setStroke(dp(1), stroke);
+        return drawable;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private int getStatusBarHeight() {
+        int resourceId = getResources().getIdentifier("status_bar_height", "dimen", "android");
+        if (resourceId > 0) {
+            return getResources().getDimensionPixelSize(resourceId);
+        }
+        return 0;
+    }
+
+    private static final class HostedApp {
+        final String id;
+        final String title;
+        final String desk;
+        final String launchMode;
+        final String androidPackage;
+        final String startUrl;
+        final String hostPatp;
+        final int tileColor;
+
+        HostedApp(String id, String title, String desk, String launchMode, String androidPackage,
+                String startUrl, String hostPatp, int tileColor) {
+            this.id = cleanString(id);
+            this.title = cleanString(title);
+            this.desk = cleanString(desk);
+            this.launchMode = cleanString(launchMode);
+            this.androidPackage = cleanString(androidPackage);
+            this.startUrl = cleanString(startUrl);
+            this.hostPatp = cleanString(hostPatp);
+            this.tileColor = tileColor;
+        }
+
+        String subtitle() {
+            if (!canOpen()) {
+                return "moon metadata - no launch URL yet";
+            }
+            if (TextUtils.isEmpty(desk)) {
+                return "ship app";
+            }
+            return desk.indexOf(' ') >= 0 ? desk : "%" + desk;
+        }
+
+        String provenance(String fallbackHost) {
+            String host = !TextUtils.isEmpty(hostPatp) ? hostPatp : cleanString(fallbackHost);
+            if (TextUtils.isEmpty(host)) {
+                return "urbit-native";
+            }
+            return host + " · urbit-native";
+        }
+
+        boolean canOpen() {
+            if (LAUNCH_NATIVE.equals(launchMode)) {
+                return !TextUtils.isEmpty(androidPackage);
+            }
+            if (LAUNCH_PWA.equals(launchMode) || LAUNCH_LOCAL_WEBVIEW.equals(launchMode)
+                    || LAUNCH_BROWSER.equals(launchMode)) {
+                return !TextUtils.isEmpty(startUrl);
+            }
+            return false;
+        }
+
+        String pendingReason() {
+            if (LAUNCH_PWA.equals(launchMode) || LAUNCH_LOCAL_WEBVIEW.equals(launchMode)) {
+                return "Hosted app is missing a URL";
+            }
+            return "This app does not expose a mobile URL yet";
+        }
+
+        boolean isTlonMessenger() {
+            return TLON_APP_ID.equals(id)
+                    || TLON_DESK.equals(stripLeadingSigil(desk))
+                    || title.toLowerCase(java.util.Locale.US).contains("tlon");
+        }
+
+        String primaryActionLabel(Context context) {
+            if (LAUNCH_LOCAL_WEBVIEW.equals(launchMode)) {
+                return "Open";
+            }
+            if (isTlonMessenger()) {
+                return isInstalled(context, TLON_PACKAGE) ? "App" : "Browser";
+            }
+            if (LAUNCH_PWA.equals(launchMode) || LAUNCH_BROWSER.equals(launchMode)) {
+                return "Browser";
+            }
+            return "Open";
+        }
+
+        private static String stripLeadingSigil(String value) {
+            String clean = cleanString(value);
+            return clean.startsWith("%") ? clean.substring(1) : clean;
+        }
+
+        private static boolean isInstalled(Context context, String packageName) {
+            if (context == null || TextUtils.isEmpty(packageName)) {
+                return false;
+            }
+            try {
+                context.getPackageManager().getPackageInfo(packageName, 0);
+                return true;
+            } catch (PackageManager.NameNotFoundException e) {
+                return false;
+            }
+        }
+    }
+}
