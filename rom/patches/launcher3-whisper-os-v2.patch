+    private void pinHostedApp(HostedApp app) {
+        if (isHostedAppPinned(this, app.id)) {
+            Toast.makeText(this, app.title + " is already on Home", Toast.LENGTH_SHORT).show();
+            recreate();
+            return;
+        }
+
+        savePendingPin(app);
+        startActivity(new Intent(Intent.ACTION_MAIN)
+                .addCategory(Intent.CATEGORY_HOME)
+                .setFlags(Intent.FLAG_ACTIVITY_NEW_TASK));
+    }
+
+    private void unpinHostedApp(HostedApp app) {
+        int deleted = deletePinnedHostedApp(this, app.id);
+        if (deleted <= 0) {
+            Toast.makeText(this, app.title + " was not on Home", Toast.LENGTH_SHORT).show();
+            recreate();
+            return;
+        }
+
+        Launcher launcher = Launcher.ACTIVITY_TRACKER.getCreatedContext();
+        if (launcher != null) {
+            launcher.getModel().forceReload();
+        }
+        Toast.makeText(this, app.title + " removed from Home", Toast.LENGTH_SHORT).show();
+        recreate();
+    }
+
+    public static void maybeCompletePendingPin(Launcher launcher) {
+        if (launcher == null) {
+            return;
+        }
+        android.content.SharedPreferences prefs = launcher.getSharedPreferences(PREFS,
+                Context.MODE_PRIVATE);
+        if (!prefs.getBoolean(PREF_PENDING_PIN, false)) {
+            return;
+        }
+
+        HostedApp app = new HostedApp(
+                prefs.getString(PREF_ID, ""),
+                prefs.getString(PREF_TITLE, ""),
+                prefs.getString(PREF_DESK, ""),
+                prefs.getString(PREF_LAUNCH_MODE, ""),
+                prefs.getString(PREF_ANDROID_PACKAGE, ""),
+                prefs.getString(PREF_START_URL, ""),
+                prefs.getString(PREF_HOST_PATP, ""),
+                prefs.getInt(PREF_TILE_COLOR, AMBER));
+        prefs.edit().clear().apply();
+
+        if (!app.canOpen()) {
+            Toast.makeText(launcher, "Hosted app is not ready to pin", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        if (isHostedAppPinned(launcher, app.id)) {
+            Toast.makeText(launcher, app.title + " is already on Home", Toast.LENGTH_SHORT).show();
+            return;
+        }
+
+        WorkspaceItemInfo info = createWorkspaceItem(launcher, app);
+        launcher.getAccessibilityDelegate().addToWorkspace(info, false /* accessibility */,
+                success -> Toast.makeText(launcher,
+                        success ? app.title + " pinned to Home" : "No room on Home",
+                        Toast.LENGTH_SHORT).show());
+    }
+
+    private void savePendingPin(HostedApp app) {
+        getSharedPreferences(PREFS, Context.MODE_PRIVATE).edit()
+                .putBoolean(PREF_PENDING_PIN, true)
+                .putString(PREF_ID, app.id)
+                .putString(PREF_TITLE, app.title)
+                .putString(PREF_DESK, app.desk)
+                .putString(PREF_LAUNCH_MODE, app.launchMode)
+                .putString(PREF_ANDROID_PACKAGE, app.androidPackage)
+                .putString(PREF_START_URL, app.startUrl)
+                .putString(PREF_HOST_PATP, !TextUtils.isEmpty(app.hostPatp) ? app.hostPatp
+                        : mShipName)
+                .putInt(PREF_TILE_COLOR, app.tileColor)
+                .apply();
+    }
