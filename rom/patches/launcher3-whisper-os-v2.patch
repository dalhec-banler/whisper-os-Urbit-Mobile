+    private int findPreferredHostedSpace(Workspace<?> workspace, IntArray workspaceScreens,
+            ItemInfo info, int[] outCoordinates) {
+        if (!isHostedWorkspaceItem(info) || info.spanX != 1 || info.spanY != 1) {
+            return -1;
+        }
+
+        int screenIndex = workspace.getCurrentPage();
+        int screenId = workspaceScreens.get(screenIndex);
+        CellLayout layout = (CellLayout) workspace.getPageAt(screenIndex);
+        if (findHostedBandCell(layout, outCoordinates)) {
+            return screenId;
+        }
+
+        for (screenIndex = 0; screenIndex < workspaceScreens.size(); screenIndex++) {
+            screenId = workspaceScreens.get(screenIndex);
+            layout = (CellLayout) workspace.getPageAt(screenIndex);
+            if (findHostedBandCell(layout, outCoordinates)) {
+                return screenId;
+            }
+        }
+        return -1;
+    }
+
+    private boolean findHostedBandCell(CellLayout layout, int[] outCoordinates) {
+        int firstHostedRow = Math.min(2, layout.getCountY() - 1);
+        for (int y = firstHostedRow; y < layout.getCountY(); y++) {
+            for (int x = 0; x < layout.getCountX(); x++) {
+                if (layout.isRegionVacant(x, y, 1, 1)) {
+                    outCoordinates[0] = x;
+                    outCoordinates[1] = y;
+                    return true;
+                }
+            }
+        }
+        return false;
+    }
