+    private static Set<String> loadPinnedHostedIds(Context context) {
+        HashSet<String> ids = new HashSet<>();
+        File dbFile = context.getDatabasePath(InvariantDeviceProfile.INSTANCE.get(context).dbFile);
+        if (!dbFile.exists()) {
