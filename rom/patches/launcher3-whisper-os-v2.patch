+            WhisperAppProvenance.SYSTEM -> "system"
+            WhisperAppProvenance.STORE -> "sandboxed · app store"
+            WhisperAppProvenance.URBIT -> getUrbitProvenanceText(itemInfo)
+            WhisperAppProvenance.SANDBOXED -> "sandboxed · third-party"
+            else -> ""
+        }
