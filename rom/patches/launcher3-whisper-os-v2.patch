+                return "$hostPatp · urbit-native"
+            }
+        }
+
+        val packageName = itemInfo.targetPackage ?: return "urbit-native"
+        return if (packageName.startsWith("network.tlon.")) {
+            "~tlon · urbit-native"
+        } else if (packageName.startsWith("io.nativeplanet.")) {
+            "~nativeplanet · urbit-native"
+        } else {
+            "urbit-native"
+        }
+    }
