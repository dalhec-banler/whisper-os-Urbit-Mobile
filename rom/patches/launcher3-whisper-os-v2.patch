+    public static List<AppInfo> loadSearchableHostedApps(Context context) {
+        ArrayList<AppInfo> results = new ArrayList<>();
+        String hostPatp = loadShipName(context);
+
+        try {
+            Bundle result = context.getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getHostedApps", null, null);
+            if (result == null) {
+                return results;
+            }
+            String json = result.getString("json", "");
+            if (TextUtils.isEmpty(json)) {
+                return results;
+            }
+            JSONArray array = new JSONObject(json).optJSONArray("apps");
+            if (array == null) {
+                return results;
+            }
+
+            for (int i = 0; i < array.length(); i++) {
+                JSONObject app = array.optJSONObject(i);
+                if (app == null) {
+                    continue;
+                }
+                String id = cleanJsonString(app, "id");
+                String title = cleanJsonString(app, "title");
+                if (TextUtils.isEmpty(id) || TextUtils.isEmpty(title)) {
+                    continue;
+                }
+
+                String desk = cleanJsonString(app, "desk");
+                String launchMode = normalizeLaunchMode(cleanJsonString(app, "launchMode"));
+                String androidPackage = cleanJsonString(app, "androidPackage");
+                String startUrl = cleanJsonString(app, "startUrl");
+                String basePath = cleanJsonString(app, "basePath");
+                if (TextUtils.isEmpty(startUrl) && !TextUtils.isEmpty(basePath)) {
+                    startUrl = LOCAL_EYRE_ORIGIN + basePath;
+                }
+
+                HostedApp hostedApp = new HostedApp(id, title, desk, launchMode, androidPackage,
+                        startUrl, hostPatp,
+                        parseColor(cleanJsonString(app, "tileColor"), AMBER));
+                AppInfo info = createSearchResult(context, hostedApp);
+                results.add(info);
+            }
+        } catch (Exception ignored) {
+            results.clear();
+        }
+
+        return results;
+    }
+
+    private static AppInfo createSearchResult(Context context, HostedApp app) {
+        Intent launch = createHostedLaunchIntent(context, app);
+        AppInfo info = new AppInfo(launch.getComponent(), app.title,
+                android.os.Process.myUserHandle(), launch);
+        info.container = LauncherSettings.Favorites.CONTAINER_ALL_APPS;
+        info.sectionName = "HOSTED";
+        info.bitmap = BitmapInfo.of(createHostedIcon(context, app), app.tileColor,
+                IconShape.EMPTY);
+        info.contentDescription = app.title;
+        return info;
+    }
+
+    private static String loadShipName(Context context) {
+        try {
+            Bundle result = context.getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getRuntime", null, null);
+            if (result == null) {
+                return "";
+            }
+            String json = result.getString("json", "");
+            if (TextUtils.isEmpty(json)) {
+                return "";
+            }
+            return cleanJsonString(new JSONObject(json), "shipName");
+        } catch (Exception ignored) {
+            return "";
+        }
+    }
