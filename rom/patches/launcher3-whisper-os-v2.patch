+    private void handleOpenHostedApp(HostedApp app) {
+        Log.d(TAG, "open hosted app id=" + app.id + " mode=" + app.launchMode
+                + " nativePackage=" + app.androidPackage);
+        if (!app.canOpen()) {
+            Toast.makeText(this, app.pendingReason(), Toast.LENGTH_SHORT).show();
+            return;
+        }
+        if (LAUNCH_LOCAL_WEBVIEW.equals(app.launchMode)) {
+            openHostedShell(app);
+        } else if (app.isTlonMessenger()) {
+            openTlonAppOrBrowser(app);
+        } else if (LAUNCH_NATIVE.equals(app.launchMode)) {
+            openNativeApp(app);
+        } else if (LAUNCH_PWA.equals(app.launchMode) || LAUNCH_BROWSER.equals(app.launchMode)) {
+            openBrowserFallback(app.startUrl);
+        } else {
+            Toast.makeText(this, "Hosted app shell is not installed yet", Toast.LENGTH_SHORT)
+                    .show();
+        }
+    }
+
+    private void openTlonAppOrBrowser(HostedApp app) {
+        if (isPackageInstalled(TLON_PACKAGE)) {
+            openNativePackage(TLON_PACKAGE);
+            return;
+        }
+        if (!TextUtils.isEmpty(app.startUrl)) {
+            Toast.makeText(this, "Opening Tlon in the browser/PWA surface",
+                    Toast.LENGTH_SHORT).show();
+            openBrowserFallback(app.startUrl);
+            return;
+        }
+        openTlonStoreListing();
+    }
+
+    private void openNativeApp(HostedApp app) {
+        if (TextUtils.isEmpty(app.androidPackage)) {
+            Toast.makeText(this, "Native app is not installed", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        openNativePackage(app.androidPackage);
+    }
+
+    private void openNativePackage(String packageName) {
+        Intent intent = getPackageManager().getLaunchIntentForPackage(packageName);
+        if (intent == null) {
+            Toast.makeText(this, "Native app is not installed", Toast.LENGTH_SHORT).show();
+            return;
+        }
+        startActivity(intent);
+    }
+
+    private void openHostedShell(HostedApp app) {
+        try {
+            startActivity(new Intent(this, WhisperHostedWebActivity.class)
+                    .putExtra(WhisperHostedWebActivity.EXTRA_TITLE, app.title)
+                    .putExtra(WhisperHostedWebActivity.EXTRA_SUBTITLE, app.subtitle())
+                    .putExtra(WhisperHostedWebActivity.EXTRA_DESK, app.desk)
+                    .putExtra(WhisperHostedWebActivity.EXTRA_URL, app.startUrl));
+        } catch (RuntimeException e) {
+            Log.e(TAG, "failed to start hosted app shell", e);
+            Toast.makeText(this, "Hosted app shell failed to start", Toast.LENGTH_SHORT).show();
+        }
