+                + "    }) || '';\n"
+                + "    if (" + jsString(patp) + " && authCookie) {\n"
+                + "      localStorage.setItem('store', JSON.stringify({\n"
+                + "        ship: " + jsString(patp) + ",\n"
+                + "        shipUrl: " + jsString(LOCAL_EYRE_ORIGIN) + ",\n"
+                + "        authCookie: authCookie,\n"
+                + "        authType: 'self',\n"
+                + "        needsSplashSequence: false\n"
+                + "      }));\n"
+                + "    }\n"
+                + "  } catch (e) {}\n"
+                + "})();\n";
