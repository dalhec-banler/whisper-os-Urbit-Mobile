+                .putExtra("hostPatp", app.hostPatp);
+    }
+
+    private static final int HOSTED_ICON_SIZE = 144;
+    private static final java.util.Map<String, Bitmap> sHostedIconCache =
+            java.util.Collections.synchronizedMap(new java.util.HashMap<>());
+
+    /**
+     * Real Docket tile image (cached by the controller, served through the
+     * provider) composed over the tile color; Whisper glyph as fallback.
+     */
+    private static Bitmap createHostedIcon(Context context, HostedApp app) {
+        Bitmap cached = sHostedIconCache.get(app.id);
+        if (cached != null) {
+            return cached;
+        }
+
+        Bitmap icon = null;
+        Bitmap tile = loadTileImage(context, app.id);
+        if (tile != null) {
+            icon = composeTileIcon(tile, app.tileColor);
+        }
+        if (icon == null) {
+            icon = WhisperAppGlyphs.createIcon(app.id, app.desk, app.hostPatp,
+                    HOSTED_ICON_SIZE);
+        }
+        sHostedIconCache.put(app.id, icon);
+        return icon;
+    }
+
+    private static Bitmap loadTileImage(Context context, String id) {
+        if (TextUtils.isEmpty(id)) {
+            return null;
+        }
+        try {
+            Bundle result = context.getContentResolver().call(
+                    Uri.parse(CONTROLLER_AUTHORITY), "getHostedAppIcon", id, null);
+            if (result == null) {
+                return null;
+            }
+            byte[] bytes = result.getByteArray("bytes");
+            if (bytes == null || bytes.length == 0) {
+                return null;
+            }
+            return android.graphics.BitmapFactory.decodeByteArray(bytes, 0, bytes.length);
+        } catch (Exception e) {
+            Log.w(TAG, "tile image load failed for " + id + ": "
+                    + e.getClass().getSimpleName());
+            return null;
+        }
+    }
+
+    private static Bitmap composeTileIcon(Bitmap tile, int tileColor) {
+        Bitmap bitmap = Bitmap.createBitmap(HOSTED_ICON_SIZE, HOSTED_ICON_SIZE,
+                Bitmap.Config.ARGB_8888);
+        Canvas canvas = new Canvas(bitmap);
+        canvas.drawColor(tileColor);
+
+        // Center-crop the tile image full-bleed, the way Landscape draws tiles.
+        float scale = Math.max(
+                (float) HOSTED_ICON_SIZE / tile.getWidth(),
+                (float) HOSTED_ICON_SIZE / tile.getHeight());
+        float width = tile.getWidth() * scale;
+        float height = tile.getHeight() * scale;
+        float left = (HOSTED_ICON_SIZE - width) / 2f;
+        float top = (HOSTED_ICON_SIZE - height) / 2f;
+        Paint paint = new Paint(Paint.ANTI_ALIAS_FLAG | Paint.FILTER_BITMAP_FLAG);
+        canvas.drawBitmap(tile, null, new RectF(left, top, left + width, top + height), paint);
+        return bitmap;
+    }
+
+    private static int inkFor(int color) {
+        double luminance = 0.2126 * Color.red(color)
+                + 0.7152 * Color.green(color)
+                + 0.0722 * Color.blue(color);
+        return luminance > 150 ? Color.rgb(16, 14, 10) : PAPER;
+    }
+
+    private static int parseColor(String value, int fallback) {
+        if (TextUtils.isEmpty(value)) {
+            return fallback;
+        }
+        try {
