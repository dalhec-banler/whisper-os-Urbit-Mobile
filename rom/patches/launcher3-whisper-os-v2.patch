+
+    private String deskForSessionBootstrap() {
+        String desk = cleanString(getIntent().getStringExtra(EXTRA_DESK));
+        if (!TextUtils.isEmpty(desk)) {
+            return desk.startsWith("%") ? desk.substring(1) : desk;
+        }
+        if (mInitialUri == null) {
+            return "";
+        }
+        List<String> segments = mInitialUri.getPathSegments();
+        if (segments.size() >= 2 && "apps".equals(segments.get(0))) {
+            return cleanString(segments.get(1));
+        }
+        return "";
+    }
+
+    private String shipFromRuntimeStatus() {
+        try {
+            Bundle result = getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getRuntime", null, null);
+            if (result == null) {
+                return "";
+            }
+            JSONObject obj = new JSONObject(result.getString("json", ""));
+            return cleanJsonString(obj, "shipName");
+        } catch (Exception e) {
+            return "";
+        }
+    }
+
+    private String shipFromBootPackage() {
+        try {
+            Bundle result = getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getStatus", null, null);
+            if (result == null) {
+                return "";
+            }
+            JSONObject obj = new JSONObject(result.getString("json", ""));
+            JSONObject boot = obj.optJSONObject("bootPackage");
+            return boot == null ? "" : cleanJsonString(boot, "ship");
+        } catch (Exception e) {
+            return "";
+        }
+    }
+
+    private void loadHostedUrlWithLocalSession(String url) {
+        if (!isLocalEyreUri(mInitialUri)) {
+            mWebView.loadUrl(url);
+            return;
+        }
+
+        new Thread(() -> {
+            try {
+                String code = requestLocalWebLoginCode();
+                if (!TextUtils.isEmpty(code)) {
+                    loginLocalEyre(code, mInitialUri);
+                }
+            } catch (Exception e) {
+                Log.w("WhisperHostedWeb", "Local Eyre auth bootstrap failed: "
+                        + e.getClass().getSimpleName());
+            }
+
+            runOnUiThread(() -> {
+                if (mWebView != null) {
+                    mWebView.loadUrl(url);
+                }
+            });
+        }, "WhisperEyreLogin").start();
+    }
+
+    private void logBootstrapState(WebView view) {
+        String currentUrl = view == null ? null : view.getUrl();
+        if (TextUtils.isEmpty(currentUrl) || !isLocalEyreUri(Uri.parse(currentUrl))) {
+            return;
+        }
+        view.evaluateJavascript("(function(){"
+                + "var cookie=(document.cookie||'').replace(/=[^;]*/g,'=<redacted>');"
+                + "return JSON.stringify({href:location.href,ship:window.ship||null,"
+                + "our:window.our||null,desk:window.desk||null,cookie:cookie,"
+                + "hasStore:!!localStorage.getItem('store')});"
+                + "})()", value -> Log.d("WhisperHostedWeb", "bootstrap=" + value));
+    }
+
+    //  Tlon's web build animates its Tamagui bottom-sheets with react-native-
+    //  reanimated. In the Android System WebView reanimated cannot resolve the
+    //  sheet's DOM node, so the enter animation never runs and the sheet's wrapper
+    //  is left translated far below the viewport. That leaves every sheet-driven
+    //  action (New DM, New group, context menus) invisible. This observer settles
+    //  any parked sheet wrapper back to rest and reveals its backdrop, so the
+    //  sheets are usable. It is a no-op for hosted apps that do not use Tamagui.
+    private void injectSheetAnimationFix(WebView view) {
+        if (view == null) {
+            return;
+        }
+        view.evaluateJavascript(""
+                + "(function(){"
+                + "  if (window.__whisperSheetFix) return;"
+                + "  window.__whisperSheetFix = true;"
+                + "  function translateY(el){"
+                + "    var t = getComputedStyle(el).transform;"
+                + "    if (!t || t === 'none') return 0;"
+                + "    var m = t.match(/matrix\\(([^)]+)\\)/);"
+                + "    if (m) return Math.abs(parseFloat(m[1].split(',')[5]) || 0);"
+                + "    var m2 = t.match(/translateY\\(([-0-9.]+)/);"
+                + "    return m2 ? Math.abs(parseFloat(m2[1])) : 0;"
+                + "  }"
+                + "  function settle(){"
+                + "    document.querySelectorAll('.is_SheetFrame').forEach(function(frame){"
+                + "      var el = frame;"
+                + "      for (var i = 0; i < 6 && el; i++){"
+                + "        if (translateY(el) > 1000) el.style.setProperty('transform','none','important');"
+                + "        el = el.parentElement;"
+                + "      }"
+                + "      frame.style.setProperty('opacity','1','important');"
+                + "    });"
+                + "    document.querySelectorAll('.is_SheetOverlay').forEach(function(o){"
+                + "      o.style.setProperty('opacity','0.32','important');"
+                + "      o.style.setProperty('pointer-events','auto','important');"
+                + "    });"
+                + "  }"
+                + "  var scheduled = false;"
+                + "  function schedule(){"
+                + "    if (scheduled) return;"
+                + "    scheduled = true;"
+                + "    requestAnimationFrame(function(){ scheduled = false; settle(); });"
+                + "  }"
+                + "  new MutationObserver(schedule).observe("
+                + "    document.documentElement, {childList:true, subtree:true});"
+                + "  settle();"
+                + "})();", null);
+    }
+
+    private String requestLocalWebLoginCode() throws Exception {
+        Bundle result = getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                "getWebLoginCode", null, null);
+        if (result == null) {
+            return null;
+        }
+
+        String json = result.getString("json", "");
+        if (TextUtils.isEmpty(json)) {
+            return null;
+        }
+
+        JSONObject obj = new JSONObject(json);
+        if (!obj.optBoolean("ok", false)) {
+            return null;
+        }
+        return obj.optString("code", null);
+    }
+
+    private boolean loginLocalEyre(String code, Uri redirectUri) throws Exception {
+        HttpURLConnection connection = null;
+        try {
+            URL url = new URL(LOCAL_EYRE_ORIGIN + "/~/login");
+            connection = (HttpURLConnection) url.openConnection();
+            connection.setConnectTimeout(EYRE_LOGIN_TIMEOUT_MS);
+            connection.setReadTimeout(EYRE_LOGIN_TIMEOUT_MS);
+            connection.setInstanceFollowRedirects(false);
+            connection.setRequestMethod("POST");
+            connection.setDoOutput(true);
+            connection.setRequestProperty("Content-Type", "application/x-www-form-urlencoded");
+
+            String body = "password=" + encode(code)
+                    + "&redirect=" + encode(redirectPath(redirectUri));
+            byte[] bodyBytes = body.getBytes(StandardCharsets.UTF_8);
+            connection.setFixedLengthStreamingMode(bodyBytes.length);
+            try (OutputStream out = connection.getOutputStream()) {
+                out.write(bodyBytes);
+            }
+
+            int status = connection.getResponseCode();
+            boolean storedCookie = storeCookies(connection.getHeaderFields());
+            return status >= 200 && status < 400 && storedCookie;
+        } finally {
+            if (connection != null) {
+                connection.disconnect();
+            }
+        }
+    }
+
+    private boolean storeCookies(Map<String, List<String>> headers) {
+        if (headers == null || headers.isEmpty()) {
+            return false;
+        }
+
+        CookieManager cookieManager = CookieManager.getInstance();
+        cookieManager.setAcceptCookie(true);
+
+        boolean stored = false;
+        for (Map.Entry<String, List<String>> entry : headers.entrySet()) {
+            if (entry.getKey() == null || !"Set-Cookie".equalsIgnoreCase(entry.getKey())) {
+                continue;
+            }
+            List<String> values = entry.getValue();
+            if (values == null) {
+                continue;
+            }
+            for (String cookie : values) {
+                if (!TextUtils.isEmpty(cookie)) {
+                    cookieManager.setCookie(LOCAL_EYRE_ORIGIN, cookie);
+                    stored = true;
+                }
+            }
+        }
+
+        if (stored) {
+            cookieManager.flush();
+        }
+        return stored;
+    }
+
+    private String redirectPath(Uri uri) {
+        String path = uri == null ? null : uri.getEncodedPath();
+        if (TextUtils.isEmpty(path)) {
+            path = "/";
+        }
+        String query = uri == null ? null : uri.getEncodedQuery();
+        if (!TextUtils.isEmpty(query)) {
+            path += "?" + query;
+        }
+        return path;
+    }
+
+    private String encode(String value) throws Exception {
+        return URLEncoder.encode(value == null ? "" : value, StandardCharsets.UTF_8.name());
+    }
+
+    private void showHostedError(String message) {
+        if (mShowingError || mWebView == null) {
+            return;
+        }
+        mShowingError = true;
+        mProgress.setVisibility(View.GONE);
+        if (mLoadingOverlay != null) {
