+            int deleted = 0;
+            for (String rowId : idsToDelete) {
+                deleted += db.delete(LauncherSettings.Favorites.TABLE_NAME,
+                        LauncherSettings.Favorites._ID + "=?", new String[]{rowId});
+            }
+            return deleted;
+        } catch (Exception e) {
+            Log.w(TAG, "failed to delete pinned hosted app", e);
+            return 0;
+        }
+    }
