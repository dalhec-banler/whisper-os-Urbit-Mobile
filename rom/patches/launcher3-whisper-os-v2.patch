+    private List<HostedApp> readHostedAppsFromProvider() {
+        ArrayList<HostedApp> apps = new ArrayList<>();
+
+        try {
+            Bundle result = getContentResolver().call(Uri.parse(CONTROLLER_AUTHORITY),
+                    "getHostedApps", null, null);
+            if (result == null) {
+                return apps;
+            }
+            String json = result.getString("json", "");
+            if (TextUtils.isEmpty(json)) {
+                return apps;
+            }
+            JSONArray array = new JSONObject(json).optJSONArray("apps");
+            if (array == null) {
+                return apps;
+            }
+
+            for (int i = 0; i < array.length(); i++) {
+                JSONObject app = array.optJSONObject(i);
+                if (app == null) {
+                    continue;
+                }
+                String id = cleanJsonString(app, "id");
+                String title = cleanJsonString(app, "title");
+                String desk = cleanJsonString(app, "desk");
+                String launchMode = normalizeLaunchMode(cleanJsonString(app, "launchMode"));
+                String androidPackage = cleanJsonString(app, "androidPackage");
+                String startUrl = cleanJsonString(app, "startUrl");
+                String basePath = cleanJsonString(app, "basePath");
+                if (TextUtils.isEmpty(startUrl) && !TextUtils.isEmpty(basePath)) {
+                    startUrl = LOCAL_EYRE_ORIGIN + basePath;
+                }
+                if (TextUtils.isEmpty(id) || TextUtils.isEmpty(title)) {
+                    continue;
+                }
+                apps.add(new HostedApp(id, title, desk, launchMode, androidPackage, startUrl,
+                        mShipName,
+                        parseColor(cleanJsonString(app, "tileColor"), AMBER)));
+            }
+            sHostedIconCache.clear();
+        } catch (Exception ignored) {
+            apps.clear();
+        }
+        return apps;
+    }
