+        }
+
+        String title = getIntent().getStringExtra(EXTRA_TITLE);
+        String safeTitle = TextUtils.htmlEncode(TextUtils.isEmpty(title) ? "Urbit App" : title);
+        String safeMessage = TextUtils.htmlEncode(message);
+        String html = "<!doctype html><html><head><meta name=\"viewport\" "
+                + "content=\"width=device-width,initial-scale=1\">"
+                + "<style>body{margin:0;background:#f4f1ec;color:#1a1916;"
+                + "font-family:sans-serif;padding:32px 24px;}"
+                + ".eyebrow{color:#f3a712;font:700 11px monospace;"
+                + "letter-spacing:.16em;text-transform:uppercase;}"
+                + "h1{font-size:34px;line-height:1.05;margin:18px 0 14px;}"
+                + "p{color:rgba(26,25,22,.55);font-size:17px;line-height:1.45;}"
+                + ".panel{border:1px solid rgba(26,25,22,.1);background:#f4f1ec;"
+                + "border-radius:0;padding:18px;margin-top:24px;}</style></head>"
+                + "<body><div class=\"eyebrow\">HOSTED</div><h1>" + safeTitle + "</h1>"
+                + "<div class=\"panel\"><p>" + safeMessage + "</p>"
+                + "<p>We can launch the app shell, but the running moon has not provided "
+                + "the correct mobile entrypoint yet.</p></div></body></html>";
+        mWebView.loadDataWithBaseURL("https://nativeplanet.local/", html, "text/html",
+                "UTF-8", null);
+    }
+
+    private boolean isAllowedHostedUrl(String value) {
+        Uri uri = Uri.parse(value);
+        if (!isLaunchableHostedUri(uri)) {
+            return false;
+        }
+
+        String host = uri.getHost();
+        String initialHost = mInitialUri == null ? "" : mInitialUri.getHost();
+        String initialScheme = mInitialUri == null ? "" : mInitialUri.getScheme();
+        return TextUtils.equals(host, initialHost)
+                && TextUtils.equals(uri.getScheme(), initialScheme);
+    }
+
+    private static boolean isLaunchableHostedUri(Uri uri) {
+        String scheme = uri.getScheme();
+        String host = uri.getHost();
+        if (TextUtils.isEmpty(scheme) || TextUtils.isEmpty(host)) {
+            return false;
+        }
+        if ("127.0.0.1".equals(host) || "localhost".equals(host)) {
+            return "http".equals(scheme) || "https".equals(scheme);
+        }
+        return "https".equals(scheme);
+    }
+
+    private static boolean isLocalEyreUri(Uri uri) {
+        if (uri == null) {
+            return false;
+        }
+        String host = uri.getHost();
+        return "http".equals(uri.getScheme())
+                && ("127.0.0.1".equals(host) || "localhost".equals(host))
+                && uri.getPort() == 8080;
+    }
+
+    private static String cleanJsonString(JSONObject object, String key) {
+        if (object == null || TextUtils.isEmpty(key) || !object.has(key) || object.isNull(key)) {
+            return "";
+        }
+        return cleanString(object.optString(key, ""));
+    }
+
+    private static String cleanString(String value) {
+        if (TextUtils.isEmpty(value) || "null".equalsIgnoreCase(value.trim())) {
+            return "";
+        }
+        return value.trim();
+    }
+
+    private static String stripSig(String value) {
+        String clean = cleanString(value);
+        return clean.startsWith("~") ? clean.substring(1) : clean;
+    }
+
+    private static String ensureSig(String value) {
+        String clean = cleanString(value);
+        if (TextUtils.isEmpty(clean)) {
+            return "";
+        }
+        return clean.startsWith("~") ? clean : "~" + clean;
+    }
+
+    private static String jsString(String value) {
+        String clean = value == null ? "" : value;
+        return JSONObject.quote(clean);
+    }
+
+    private TextView text(String value, int sp, int color, int style) {
+        return text(value, sp, color, style, Typeface.DEFAULT);
+    }
+
+    private TextView text(String value, int sp, int color, int style, Typeface family) {
+        TextView view = new TextView(this);
+        view.setText(value);
+        view.setTextSize(sp);
+        view.setTextColor(color);
+        view.setIncludeFontPadding(true);
+        view.setTypeface(family, style);
+        return view;
+    }
+
+    private GradientDrawable box(int fill, int stroke, int radius) {
+        GradientDrawable drawable = new GradientDrawable();
+        drawable.setColor(fill);
+        drawable.setCornerRadius(radius);
+        drawable.setStroke(dp(1), stroke);
+        return drawable;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private int getStatusBarHeight() {
+        int resourceId = getResources().getIdentifier("status_bar_height", "dimen", "android");
+        return resourceId > 0 ? getResources().getDimensionPixelSize(resourceId) : 0;
+    }
+}
