diff --git a/res/layout/whisper_popup_provenance_header.xml b/res/layout/whisper_popup_provenance_header.xml
new file mode 100644
index 0000000000..eb33882378
--- /dev/null
+++ b/res/layout/whisper_popup_provenance_header.xml
@@ -0,0 +1,27 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!-- Whisper OS popup provenance header - shows app origin (world + host) -->
+<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
+    android:id="@+id/whisper_popup_provenance_header"
+    android:layout_width="match_parent"
+    android:layout_height="wrap_content"
+    android:orientation="horizontal"
+    android:paddingHorizontal="14dp"
+    android:paddingVertical="10dp"
+    android:background="?attr/popupColorPrimary">
+
+    <View
+        android:id="@+id/whisper_provenance_bar"
+        android:layout_width="3dp"
+        android:layout_height="match_parent"
+        android:layout_marginEnd="10dp" />
+
+    <TextView
+        android:id="@+id/whisper_provenance_text"
+        android:layout_width="wrap_content"
+        android:layout_height="wrap_content"
+        android:fontFamily="monospace"
+        android:textSize="11sp"
+        android:letterSpacing="0.03"
+        android:textColor="@color/whisper_paper_dim" />
+
+</LinearLayout>
diff --git a/res/layout/whisper_section_header.xml b/res/layout/whisper_section_header.xml
new file mode 100644
index 0000000000..cf9433364b
--- /dev/null
+++ b/res/layout/whisper_section_header.xml
@@ -0,0 +1,31 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!-- Whisper OS section header for SYSTEM/HOSTED app classification -->
+<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
+    android:layout_width="match_parent"
+    android:layout_height="wrap_content"
+    android:orientation="horizontal"
+    android:gravity="center_vertical"
+    android:paddingHorizontal="22dp"
+    android:paddingTop="16dp"
+    android:paddingBottom="8dp"
+    android:focusable="false"
+    android:importantForAccessibility="no">
+
+    <View
+        android:id="@+id/whisper_section_line"
+        android:layout_width="12dp"
+        android:layout_height="1dp"
+        android:background="@color/whisper_ink_dim" />
+
+    <TextView
+        android:id="@+id/whisper_section_label"
+        android:layout_width="wrap_content"
+        android:layout_height="wrap_content"
+        android:layout_marginStart="8dp"
+        android:textSize="10sp"
+        android:fontFamily="monospace"
+        android:letterSpacing="0.15"
+        android:textColor="@color/whisper_ink_dim"
+        android:textAllCaps="true" />
+
+</LinearLayout>
